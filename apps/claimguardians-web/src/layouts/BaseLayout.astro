---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    {/* JSON-LD Schema Placeholder */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Claim Guardians LLC",
        "image": "",
        "url": "https://www.claimguardians.com",
        "telephone": "(555) 123-4567",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "",
          "addressLocality": "",
          "addressRegion": "FL",
          "postalCode": "",
          "addressCountry": "US"
        }
      }
    </script>
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased min-h-screen flex flex-col">
    <!-- 1. Header (Fixed Navigation) -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 font-extrabold text-2xl text-blue-900 tracking-tight">
          <span class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm shadow-sm">CG</span>
          Claim Guardians
        </a>
        
        <!-- Desktop Links -->
        <div class="hidden md:flex items-center space-x-8">
          <a href="/services" class="text-sm font-semibold text-slate-700 hover:text-blue-600 transition-colors">Services</a>
          <a href="/service-areas" class="text-sm font-semibold text-slate-700 hover:text-blue-600 transition-colors">Service Areas</a>
          <a href="/company/about-us" class="text-sm font-semibold text-slate-700 hover:text-blue-600 transition-colors">About Us</a>
          <a href="/resources" class="text-sm font-semibold text-slate-700 hover:text-blue-600 transition-colors">Resources</a>
        </div>

        <!-- CTA Button -->
        <div class="flex items-center">
          <a href="tel:5551234567" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm focus:ring-4 focus:ring-blue-100">
            Call 24/7: (555) 123-4567
          </a>
          <button class="md:hidden ml-4 text-slate-500 hover:text-slate-900 focus:outline-none">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
    </header>
    
    <main class="flex-grow">
      <slot />
    </main>

    <!-- 8. Footer -->
    <footer class="bg-slate-900 text-slate-300 py-16 mt-24 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          
          <div class="space-y-6">
            <div class="font-extrabold text-2xl text-white tracking-tight flex items-center gap-2">
              <span class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-sm">CG</span>
              Claim Guardians
            </div>
            <p class="text-sm leading-relaxed">Florida's trusted advocates. We fight for the settlement you deserve so you can focus on recovery.</p>
            <a href="tel:5551234567" class="inline-flex items-center justify-center px-5 py-2.5 text-sm font-bold text-slate-900 bg-white rounded-lg hover:bg-slate-100 transition-colors">
              Call for a Free Inspection
            </a>
          </div>

          <!-- Column 2: Services -->
          <div>
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-wider">Services</h3>
            <ul class="space-y-4 text-sm">
              <li><a href="/services/water-damage" class="hover:text-white transition-colors">Water Damage</a></li>
              <li><a href="/services/hurricane-damage" class="hover:text-white transition-colors">Hurricane Damage</a></li>
              <li><a href="/services/roof-damage" class="hover:text-white transition-colors">Roof Damage</a></li>
              <li><a href="/services/fire-damage" class="hover:text-white transition-colors">Fire Damage</a></li>
              <li><a href="/services/mold-claims" class="hover:text-white transition-colors">Mold Claims</a></li>
              <li><a href="/services/denied-claims" class="hover:text-white transition-colors">Denied Claims</a></li>
            </ul>
          </div>

          <!-- Column 3: Service Areas -->
          <div>
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-wider">Service Areas</h3>
            <ul class="space-y-4 text-sm">
              <li><a href="/service-areas/miami" class="hover:text-white transition-colors">Public Adjusters in Miami</a></li>
              <li><a href="/service-areas/fort-myers" class="hover:text-white transition-colors">Public Adjusters in Fort Myers</a></li>
              <li><a href="/service-areas/orlando" class="hover:text-white transition-colors">Public Adjusters in Orlando</a></li>
              <li><a href="/service-areas/tampa" class="hover:text-white transition-colors">Public Adjusters in Tampa</a></li>
            </ul>
          </div>

          <!-- Column 4: Legal -->
          <div>
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-wider">Legal</h3>
            <ul class="space-y-4 text-sm">
              <li><a href="/company/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/company/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a></li>
              <li class="pt-4 border-t border-slate-800">
                <span class="block text-slate-400">FAPIA License #</span>
                <span class="font-mono text-white">[Insert Number]</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="mt-16 pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center text-sm text-slate-500">
          <p>&copy; {new Date().getFullYear()} Claim Guardians LLC. All rights reserved.</p>
          <div class="mt-4 md:mt-0 flex space-x-6">
             <a href="#" class="hover:text-white">Facebook</a>
             <a href="#" class="hover:text-white">LinkedIn</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
