---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = '/images/logo-color.svg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9WTBNG5905"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-9WTBNG5905');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon Claims.png" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph Metadata -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    
    {/* JSON-LD Schema Placeholder */}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Claim Guardians LLC",
        "image": "",
        "url": "https://www.claimguardians.com",
        "telephone": "(305) 804-5489",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "",
          "addressLocality": "",
          "addressRegion": "FL",
          "postalCode": "",
          "addressCountry": "US"
        }
      }
    </script>
    <slot name="head" />
  </head>
  <body class="bg-base-bg text-text-main font-sans antialiased min-h-screen flex flex-col">
    <!-- 1. Global Header (Premium 2026 White Glassmorphism) -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-2xl border-b border-slate-200 shadow-sm supports-[backdrop-filter]:bg-white/60">
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#00808C]/5 to-transparent pointer-events-none"></div>
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-24 flex justify-between items-center relative z-10">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 font-extrabold text-2xl text-white tracking-tight group">
          <img src="/images/logo SVG.svg" alt="Claim Guardians Logo" class="h-12 w-auto transition-all duration-300 group-hover:scale-105" />
        </a>
        
        <!-- Desktop Links -->
        <div class="hidden md:flex items-center space-x-1">
          <a href="/services" class="px-4 py-2 text-sm font-bold text-slate-600 hover:text-[#00808C] hover:bg-slate-50 rounded-lg transition-all duration-200">Services</a>
          <a href="/service-areas" class="px-4 py-2 text-sm font-bold text-slate-600 hover:text-[#00808C] hover:bg-slate-50 rounded-lg transition-all duration-200">Areas We Serve</a>
          <a href="/resources" class="px-4 py-2 text-sm font-bold text-slate-600 hover:text-[#00808C] hover:bg-slate-50 rounded-lg transition-all duration-200">Resources & FAQ</a>
          <a href="/company" class="px-4 py-2 text-sm font-bold text-[#00808C] hover:text-[#00B5A6] hover:bg-slate-50 rounded-lg transition-all duration-200">Our Firm</a>
        </div>

        <!-- CTA Button & Mobile Toggle -->
        <div class="flex items-center gap-4">
          <a href="tel:3058045489" class="hidden lg:flex items-center gap-2 text-sm font-black text-[#002D51] hover:text-[#00808C] transition-colors mr-2">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00B5A6] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-[#00B5A6]"></span>
            </span>
            (305) 804-5489
          </a>
          <a href="/free-claim-review" class="hidden md:inline-flex justify-center items-center px-6 py-2.5 text-sm font-black text-white bg-[#00808C] rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-0.5 relative overflow-hidden group">
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-[100%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative">Free Claim Review</span>
          </a>
          
          <!-- Mobile Menu Button -->
          <button id="mobile-menu-open" class="md:hidden p-2 text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-[#00B5A6]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Mobile Menu Overlay (Hidden by default) -->
    <div id="mobile-menu" class="fixed inset-0 z-[100] invisible pointer-events-none transition-all duration-300">
      <!-- Backdrop -->
      <div id="mobile-menu-backdrop" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
      
      <!-- Menu Content -->
      <div id="mobile-menu-content" class="absolute right-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-out flex flex-col">
        <div class="p-6 flex items-center justify-between border-b border-slate-100">
          <img src="/images/logo SVG.svg" alt="Claim Guardians Logo" class="h-8 w-auto" />
          <button id="mobile-menu-close" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <nav class="flex-grow p-8 space-y-6 overflow-y-auto">
          <a href="/services" class="block text-xl font-bold text-slate-800 hover:text-[#00808C] transition-colors">Services</a>
          <a href="/service-areas" class="block text-xl font-bold text-slate-800 hover:text-[#00808C] transition-colors">Areas We Serve</a>
          <a href="/resources" class="block text-xl font-bold text-slate-800 hover:text-[#00808C] transition-colors">Resources & FAQ</a>
          <a href="/company" class="block text-xl font-bold text-[#00808C] hover:text-[#00B5A6] transition-colors">Our Firm</a>
          
          <div class="pt-8 border-t border-slate-100 italic text-slate-500 text-sm">
            Property insurance advocates working exclusively for the policyholder.
          </div>
        </nav>
        
        <div class="p-6 bg-slate-50 border-t border-slate-100">
          <a href="/free-claim-review" class="w-full flex justify-center items-center px-6 py-4 text-base font-black text-white bg-[#00808C] rounded-xl shadow-lg hover:bg-[#00B5A6] transition-all duration-300">
            Free Claim Review
          </a>
          <a href="tel:3058045489" class="mt-4 w-full flex justify-center items-center gap-2 text-base font-bold text-[#002D51] py-2">
            📞 (305) 804-5489
          </a>
        </div>
      </div>
    </div>
    
    <main class="flex-grow">
      <slot />
    </main>

    <!-- 8. Premium Mega Footer -->
    <footer class="bg-primary-900 border-t border-primary-700/50 relative overflow-hidden">
      <!-- Top Decorative Edge -->
      <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[#00B5A6]/50 to-transparent"></div>
      
      <!-- Pre-footer CTA Area -->
      <div class="border-b border-primary-700/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <h2 class="text-3xl font-extrabold text-white mb-2">Claim <span class="text-[#00B5A6]">Guardians</span></h2>
            <p class="text-primary-200 text-lg">Florida's elite private insurance advocates. We force them to pay.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/free-claim-review" class="px-8 py-4 text-sm font-black text-white bg-[#00808C] rounded-xl shadow-[0_10px_30px_-10px_rgba(0,128,140,0.5)] hover:shadow-[0_15px_40px_-10px_rgba(0,128,140,0.6)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center">
              Get Your Free Property Inspection
            </a>
            <a href="tel:3058045489" class="px-8 py-4 text-sm font-black text-[#00B5A6] border-2 border-[#00B5A6]/30 bg-white/5 hover:bg-[#00B5A6]/10 hover:border-[#00B5A6] rounded-xl transition-all duration-300 flex items-center justify-center">
              Call (305) 804-5489
            </a>
          </div>
        </div>
      </div>

      <!-- Main Footer Grid -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-slate-300">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
          
          <!-- Column 1: Brand & Trust (Takes up 4 cols) -->
          <div class="lg:col-span-4 space-y-8">
            <a href="/" class="inline-block mb-2 group">
              <img src="/images/logo SVG.svg" alt="Claim Guardians Logo" class="h-16 w-auto object-contain brightness-0 invert group-hover:scale-105 transition-transform" />
            </a>
            <p class="text-sm leading-relaxed text-slate-400">
              Claim Guardians LLC is a licensed Florida Public Adjusting firm dedicated strictly to the policyholder. We leverage forensic technology and policy expertise to maximize your settlement.
            </p>
            
            <div class="flex items-center gap-4 pt-4 border-t border-primary-800">
              <div class="h-14 w-28 bg-primary-800/50 rounded-xl flex flex-col items-center justify-center border border-primary-700">
                <span class="text-[10px] font-black text-[#00B5A6] uppercase tracking-tighter">Florida DFS</span>
                <span class="text-xs font-black text-white">LICENSED</span>
              </div>
              <div class="h-14 w-28 bg-primary-800/50 rounded-xl flex flex-col items-center justify-center border border-primary-700">
                <span class="text-[10px] font-black text-[#00B5A6] uppercase tracking-tighter">State of FL</span>
                <span class="text-xs font-black text-white">BONDED</span>
              </div>
              <div class="h-14 w-28 bg-primary-800/50 rounded-xl flex flex-col items-center justify-center border border-primary-700">
                <span class="text-[10px] font-black text-[#00B5A6] uppercase tracking-tighter">Zero-Risk</span>
                <span class="text-xs font-black text-white">NO FEE</span>
              </div>
            </div>
            
            <div class="pt-2">
              <p class="text-xs font-black text-slate-500 uppercase tracking-widest">Regulated by the Florida Dept. of Financial Services</p>
            </div>
          </div>

          <!-- Column 2: Legal & Company (Takes up 2 cols) -->
          <div class="lg:col-span-2">
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Our Firm</h3>
            <ul class="space-y-4 text-sm font-medium">
              <li><a href="/company" class="hover:text-[#00B5A6] transition-colors">About Guardians</a></li>
              <li><a href="/resources" class="hover:text-[#00B5A6] transition-colors">Claim Resources</a></li>
              <li><a href="/contact" class="hover:text-[#00B5A6] transition-colors">Contact Us</a></li>
              <li class="pt-4"><a href="/privacy-policy" class="text-slate-500 hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms-of-service" class="text-slate-500 hover:text-white transition-colors">Terms of Service</a></li>
            </ul>
          </div>

          <!-- Column 3: Services (Takes up 3 cols) -->
          <div class="lg:col-span-3">
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Property Claims</h3>
            <ul class="space-y-4 text-sm font-medium">
              <li><a href="/services/water-damage" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">💧 Water Damage</a></li>
              <li><a href="/services/hurricane-damage" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">🌪️ Hurricane & Wind</a></li>
              <li><a href="/services/roof-damage" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">🏠 Roof Replacements</a></li>
              <li><a href="/services/fire-damage" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">🔥 Fire & Smoke</a></li>
              <li><a href="/services/mold-claims" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">🦠 Mold Remediation</a></li>
              <li><a href="/services/denied-claims" class="hover:text-[#00B5A6] transition-colors flex items-center gap-2">⚖️ Denied/Underpaid Claims</a></li>
            </ul>
          </div>

          <!-- Column 4: Service Areas (Takes up 3 cols) -->
          <div class="lg:col-span-3">
            <h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Coverage Areas</h3>
            <div class="grid grid-cols-2 gap-4">
              <ul class="space-y-4 text-sm font-medium">
                <li><span class="text-[#00B5A6] font-bold uppercase text-xs tracking-wider">Florida</span></li>
                <li><a href="/service-areas/miami" class="hover:text-white transition-colors text-slate-400">Miami</a></li>
                <li><a href="/service-areas/fort-lauderdale" class="hover:text-white transition-colors text-slate-400">Ft. Lauderdale</a></li>
                <li><a href="/service-areas/orlando" class="hover:text-white transition-colors text-slate-400">Orlando</a></li>
                <li><a href="/service-areas/tampa" class="hover:text-white transition-colors text-slate-400">Tampa</a></li>
              </ul>
              <ul class="space-y-4 text-sm font-medium">
                <li><span class="text-[#00B5A6] font-bold uppercase text-xs tracking-wider">California</span></li>
                <li><a href="/service-areas/los-angeles" class="hover:text-white transition-colors text-slate-400">Los Angeles</a></li>
                <li><a href="/service-areas/san-francisco" class="hover:text-white transition-colors text-slate-400">San Francisco</a></li>
                <li><a href="/service-areas/san-diego" class="hover:text-white transition-colors text-slate-400">San Diego</a></li>
                <li><a href="/service-areas/sacramento" class="hover:text-white transition-colors text-slate-400">Sacramento</a></li>
              </ul>
            </div>
            <div class="mt-6 pt-6 border-t border-primary-800">
               <a href="/service-areas" class="text-[#00B5A6] font-bold text-sm hover:text-white transition-colors flex items-center gap-1">
                 View All Service Areas <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
               </a>
            </div>
          </div>

        </div>
        
        <!-- Bottom Copyright -->
        <div class="mt-16 pt-8 border-t border-primary-800 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-slate-500">
          <div class="flex flex-col md:flex-row items-center gap-2 md:gap-6 text-center md:text-left">
            <p>&copy; {new Date().getFullYear()} Claim Guardians LLC. All rights reserved.</p>
            <div class="flex gap-4">
              <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
              <a href="/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a>
            </div>
          </div>
          <p class="mt-4 md:mt-0 text-center md:text-right">
            Headquarters: <span class="text-slate-400">304 Indian Trace Unit 655, Weston, FL 33326</span>
          </p>
        </div>
      </div>
    </footer>

    <script>
      const openBtn = document.getElementById('mobile-menu-open');
      const closeBtn = document.getElementById('mobile-menu-close');
      const menu = document.getElementById('mobile-menu');
      const backdrop = document.getElementById('mobile-menu-backdrop');
      const content = document.getElementById('mobile-menu-content');
      const body = document.body;

      function openMenu() {
        menu.classList.remove('invisible', 'pointer-events-none');
        backdrop.classList.add('opacity-100');
        content.classList.remove('translate-x-full');
        body.style.overflow = 'hidden';
      }

      function closeMenu() {
        backdrop.classList.remove('opacity-100');
        content.classList.add('translate-x-full');
        body.style.overflow = '';
        
        // Wait for transition to finish
        setTimeout(() => {
          menu.classList.add('invisible', 'pointer-events-none');
        }, 300);
      }

      openBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      backdrop?.addEventListener('click', closeMenu);

      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu?.classList.contains('invisible')) {
          closeMenu();
        }
      });
    </script>
  </body>
</html>
