---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Claim Guardians | Maximizes Your Water Damage Insurance Claim" 
  description="Insurance companies routinely underpay water damage claims. Claim Guardians forces your insurer to cover the total cost of your repairs. You pay nothing upfront."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "serviceType": "Water Damage Public Adjuster",
        "provider": {
          "@type": "LocalBusiness",
          "name": "Claim Guardians LLC"
        },
        "areaServed": {
          "@type": "State",
          "name": "Florida"
        },
        "description": "Claim Guardians forces your insurer to cover the total cost of your water damage repairs."
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "Does homeowners insurance cover water damage in Florida?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Homeowners insurance covers sudden and accidental water damage, such as a burst pipe or a broken water heater. However, insurance companies often deny claims by citing \"gradual wear and tear.\" Claim Guardians fights these unfair denials and secures your payout."
          }
        }, {
          "@type": "Question",
          "name": "Should I clean up the water before the adjuster arrives?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Property owners must stop the water source to prevent further destruction. However, you should not discard damaged items. Claim Guardians documents all ruined property to ensure the insurance company pays for your total loss."
          }
        }, {
          "@type": "Question",
          "name": "How much does a water damage public adjuster charge?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Claim Guardians charges $0 for the initial property inspection. We work on a contingency basis. You pay a percentage only after we win your water damage settlement."
          }
        }]
      }
    </script>
  </Fragment>

  <!-- 1. Hero Section (Urgency + Premium 2026 Aesthetic) -->
  <header class="relative bg-[#0A0F1C] overflow-hidden pt-24 pb-32">
    <!-- Dynamic Glowing Gradient Mesh Background -->
    <div class="absolute top-0 inset-x-0 h-[600px] bg-gradient-to-b from-primary-900/50 to-transparent pointer-events-none"></div>
    <div class="absolute -top-[300px] -right-[200px] w-[800px] h-[800px] rounded-full bg-primary-600/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute -bottom-[200px] -left-[200px] w-[600px] h-[600px] rounded-full bg-accent-600/10 blur-[100px] pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-8">
      
      <!-- Breadcrumbs (Glassmorphism Pilled) -->
      <nav aria-label="Breadcrumb" class="mb-12 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-300 font-medium bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 shadow-lg">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-500">›</span></li>
          <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
          <li><span class="mx-2 text-slate-500">›</span></li>
          <li class="text-white" aria-current="page">Water Damage</li>
        </ol>
      </nav>

      <div class="max-w-4xl">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight drop-shadow-2xl">
          Claim Guardians <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-blue-200">Maximizes</span> Your Water Damage Insurance Claim.
        </h1>
        <h2 class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-3xl font-light">
          Burst pipes and hidden leaks destroy your property. Insurance companies routinely underpay water damage claims. Claim Guardians forces your insurer to cover the total cost of your repairs. You pay nothing upfront.
        </h2>
        
        <div class="flex flex-col sm:flex-row gap-5 mb-14">
          <a href="/free-claim-review" class="group relative inline-flex justify-center items-center px-10 py-4 text-lg font-bold text-white bg-accent-600 rounded-xl overflow-hidden shadow-[0_0_40px_-10px_rgba(234,88,12,0.6)] hover:shadow-[0_0_60px_-15px_rgba(234,88,12,0.8)] transition-all duration-300 hover:-translate-y-1">
            <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-[100%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative">Get a Free Water Damage Inspection</span>
          </a>
          <a href="tel:5551234567" class="inline-flex justify-center items-center px-10 py-4 text-lg font-bold text-white bg-white/10 backdrop-blur-md border border-white/20 rounded-xl hover:bg-white/20 transition-all duration-300 hover:-translate-y-1 shadow-xl">
            Call a Water Expert Now
          </a>
        </div>
        
        <!-- Trust Badges -->
        <div class="flex flex-wrap items-center gap-8 text-sm font-semibold text-slate-300">
          <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-lg border border-white/10">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-500/20 text-green-400 text-xs">✓</span>
            FAPIA Licensed
          </div>
          <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-lg border border-white/10">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-500/20 text-green-400 text-xs">✓</span>
            No Recovery, No Fee
          </div>
          <div class="flex items-center gap-3 bg-white/5 px-4 py-2 rounded-lg border border-white/10">
            <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-500/20 text-green-400 text-xs">✓</span>
            Thermal Imaging Experts
          </div>
        </div>
      </div>
    </div>
    
    <!-- Decorative bottom wave/fade -->
    <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-base-bg to-transparent"></div>
  </header>

  <!-- 2. The Problem vs. The Solution -->
  <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      
      <!-- Problem -->
      <div class="prose prose-lg prose-slate pr-0 lg:pr-8">
        <h2 class="text-3xl font-extrabold text-[#111827] mb-6">
          Insurance Adjusters Ignore Hidden Water Damage.
        </h2>
        <p class="text-text-muted leading-relaxed">
          Water travels behind walls and under floors. Your insurance company's adjuster only documents visible damage. They protect the company's profits.
        </p>
      </div>

      <!-- Solution -->
      <div class="card-surface border-primary-100 shadow-md">
        <h3 class="text-2xl font-bold text-primary-700 mb-6 flex items-center gap-3">
          <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-primary-100 text-primary-600">✓</span>
          Claim Guardians Uncovers the Truth.
        </h3>
        <ul class="space-y-5">
          <li class="flex items-start gap-4">
            <span class="text-primary-500 mt-1 flex-shrink-0">🔍</span>
            <span class="text-lg font-medium text-text-main">Our experts use thermal imaging cameras.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-primary-500 mt-1 flex-shrink-0">📸</span>
            <span class="text-lg font-medium text-text-main">We document invisible moisture and structural rot.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-primary-500 mt-1 flex-shrink-0">📝</span>
            <span class="text-lg font-medium text-text-main">Claim Guardians estimates the true cost of complete restoration.</span>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-primary-500 mt-1 flex-shrink-0">⚖️</span>
            <span class="text-lg font-medium text-text-main">Our team forces the insurance company to pay your maximum policy limit.</span>
          </li>
        </ul>
      </div>

    </div>
  </section>

  <!-- 3. The Danger of Delay (High Threat 2026 UI) -->
  <section class="relative bg-[#0A0F1C] py-32 overflow-hidden border-y border-slate-800">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-20"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-red-600/20 blur-[150px] rounded-full pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 text-4xl mb-8 shadow-[0_0_30px_rgba(220,38,38,0.3)]">
        🦠
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-8 tracking-tight">
        Standing Water Breeds Toxic Mold in <span class="text-red-500">48 Hours.</span>
      </h2>
      <p class="text-xl text-slate-300 leading-relaxed mb-12 font-light">
        Delaying your claim reduces your payout. Florida's humidity accelerates mold growth. Claim Guardians dispatches an inspector immediately. <strong class="text-white font-semibold">We protect your family's health and your financial rights.</strong>
      </p>
      <a href="tel:5551234567" class="btn-accent text-xl px-12 py-5 shadow-[0_0_40px_-5px_rgba(234,88,12,0.8)] hover:shadow-[0_0_60px_-5px_rgba(234,88,12,1)] hover:scale-105 transition-all duration-300">
        Request Immediate Assistance
      </a>
    </div>
  </section>

  <!-- 4. Proof of Success (Premium UI Card) -->
  <section class="py-32 bg-base-bg relative overflow-hidden">
    <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-green-50/50 to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#111827] mb-16 text-center tracking-tight">
        Claim Guardians Secures Massive Water Damage Payouts.
      </h2>

      <div class="max-w-3xl mx-auto bg-white rounded-3xl p-10 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)] border border-slate-100 hover:shadow-[0_30px_80px_-15px_rgba(0,0,0,0.1)] transition-all duration-500 relative group overflow-hidden">
        
        <!-- Glowing Edge Effect on Hover -->
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-green-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

        <div class="mb-8 border-b border-slate-100 pb-8">
          <span class="inline-flex items-center px-4 py-2 bg-slate-50 text-slate-600 text-sm font-bold rounded-full mb-8 border border-slate-200">
            📍 Kitchen Pipe Burst, Tampa, FL.
          </span>
          <div class="space-y-6">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center text-lg gap-2">
              <span class="text-slate-500 font-medium tracking-wide text-sm uppercase">Insurance Initial Offer</span>
              <span class="text-red-500/60 line-through font-bold text-2xl">
                $9,200 <span class="text-xs font-normal ml-2 text-slate-400 block sm:inline">(For "surface repairs")</span>
              </span>
            </div>
            
            <div class="h-px w-full bg-gradient-to-r from-transparent via-slate-100 to-transparent"></div>

            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center text-xl gap-4">
              <span class="text-[#111827] font-bold tracking-wide text-sm uppercase">Claim Guardians Settlement</span>
              <div class="flex flex-col items-end">
                <span class="text-green-600 font-black text-4xl tracking-tighter drop-shadow-sm">
                  $68,400
                </span>
                <span class="text-xs font-medium mt-1 text-green-700/70 uppercase tracking-wider">(For complete kitchen rebuild & mitigation)</span>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-slate-50 -mx-10 -mb-10 p-10">
          <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Action Taken</h4>
          <p class="text-xl font-medium text-[#111827] leading-relaxed">
            Claim Guardians proved water damage destroyed the subfloor. We reversed the insurance company's lowball offer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. AEO / LLM Optimized FAQs -->
  <section class="bg-primary-50 border-t border-primary-100 py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-12 text-center">
        Frequently Asked Questions About Water Damage Claims
      </h2>

      <div class="space-y-4">
        <details class="group card-surface p-0 [&_summary::-webkit-details-marker]:hidden hover:border-primary-200">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#111827] group-hover:text-primary-600 transition-colors">
            <span>Does homeowners insurance cover water damage in Florida?</span>
            <span class="transition group-open:rotate-180 flex-shrink-0 ml-4">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-text-muted px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4 m-0">
            Homeowners insurance covers sudden and accidental water damage, such as a burst pipe or a broken water heater. However, insurance companies often deny claims by citing "gradual wear and tear." Claim Guardians fights these unfair denials and secures your payout.
          </div>
        </details>

        <details class="group card-surface p-0 [&_summary::-webkit-details-marker]:hidden hover:border-primary-200">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#111827] group-hover:text-primary-600 transition-colors">
            <span>Should I clean up the water before the adjuster arrives?</span>
            <span class="transition group-open:rotate-180 flex-shrink-0 ml-4">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-text-muted px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4 m-0">
            Property owners must stop the water source to prevent further destruction. However, you should not discard damaged items. Claim Guardians documents all ruined property to ensure the insurance company pays for your total loss.
          </div>
        </details>

        <details class="group card-surface p-0 [&_summary::-webkit-details-marker]:hidden hover:border-primary-200">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#111827] group-hover:text-primary-600 transition-colors">
            <span>How much does a water damage public adjuster charge?</span>
            <span class="transition group-open:rotate-180 flex-shrink-0 ml-4">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-text-muted px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4 m-0">
            Claim Guardians charges $0 for the initial property inspection. We work on a contingency basis. You pay a percentage only after we win your water damage settlement.
          </div>
        </details>
      </div>

    </div>
  </section>

  <!-- 6. Service Area Context -->
  <section class="py-24 text-center px-4">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-extrabold text-[#111827] mb-4">
        Claim Guardians Serves All of Florida.
      </h2>
      <p class="text-lg text-text-muted mb-8">
        From Miami to Jacksonville, our licensed public adjusters respond rapidly to your water emergency.
      </p>
      <a href="/service-areas" class="inline-flex items-center text-primary-600 font-bold hover:text-primary-700 transition-colors text-lg group">
        View All Florida Service Areas 
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>

  <!-- Mobile Sticky CTA (Bottom Tab Bar substitute for BOF pages) -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-50 sm:hidden">
    <a href="tel:5551234567" class="btn-accent w-full text-lg animate-pulse">
      🚨 Emergency? Call Now
    </a>
  </div>

</BaseLayout>
