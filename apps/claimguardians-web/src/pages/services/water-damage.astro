---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimCalculator from '../../components/ClaimCalculator';
import EligibilityTest from '../../components/EligibilityTest';
---

<BaseLayout 
  title="Claim Guardians | Maximizes Your Water Damage Insurance Claim" 
  description="Insurance companies routinely underpay water damage claims. Claim Guardians forces your insurer to cover the total cost of your repairs. You pay nothing upfront."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "serviceType": "Water Damage Public Adjuster",
        "provider": { "@type": "LocalBusiness", "name": "Claim Guardians LLC" },
        "areaServed": { "@type": "State", "name": "Florida" },
        "description": "Claim Guardians forces your insurer to cover the total cost of your water damage repairs."
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "Does homeowners insurance cover water damage in Florida?",
          "acceptedAnswer": { "@type": "Answer", "text": "Homeowners insurance covers sudden and accidental water damage, such as a burst pipe or a broken water heater. However, insurance companies often deny claims by citing \"gradual wear and tear.\" Claim Guardians fights these unfair denials and secures your payout." }
        }, {
          "@type": "Question",
          "name": "Should I clean up the water before the adjuster arrives?",
          "acceptedAnswer": { "@type": "Answer", "text": "Property owners must stop the water source to prevent further destruction. However, you should not discard damaged items. Claim Guardians documents all ruined property to ensure the insurance company pays for your total loss." }
        }, {
          "@type": "Question",
          "name": "How much does a water damage public adjuster charge?",
          "acceptedAnswer": { "@type": "Answer", "text": "Claim Guardians charges $0 for the initial property inspection. We work on a contingency basis. You pay a percentage only after we win your water damage settlement." }
        }]
      }
    </script>
  </Fragment>

  <!-- 1. Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-water-damage.png" alt="Water damage to a Florida property" class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" loading="eager"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white" aria-current="page">Water Damage</li>
        </ol>
      </nav>

      <div class="max-w-4xl">
        <span class="eyebrow" style="color:#00B5A6;">Property Damage — Water &amp; Leaks</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians Maximizes Your Water Damage Insurance Claim.
        </h1>
        <p class="text-xl text-slate-300 mb-12 leading-relaxed max-w-3xl">
          Burst pipes and hidden leaks destroy your property. Insurance companies routinely underpay water damage claims. Claim Guardians forces your insurer to cover the total cost of your repairs. You pay nothing upfront.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 mb-12">
          <a href="/free-claim-review" class="btn-accent px-10 py-5 text-lg min-h-[60px]">Get a Free Water Damage Inspection</a>
          <a href="tel:3058045489" class="inline-flex justify-center items-center px-10 py-5 text-lg font-bold text-white bg-white/5 border-2 border-white/20 rounded-xl hover:bg-white/10 transition-all transform hover:-translate-y-1 min-h-[60px]">
            Call a Water Expert Now
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 grayscale opacity-60">
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🏛️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">DFS Licensed</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🛡️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">Policyholder Advocacy</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">⚖️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">State Bonded</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">💰</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">No-Fee Guarantee</span>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. Problem / Solution -->
  <section class="section-white">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <span class="eyebrow">The Problem</span>
          <h2 class="section-heading mb-6">Insurance Adjusters Ignore Hidden Water Damage.</h2>
          <p class="text-lg text-slate-500 leading-relaxed">
            Water travels behind walls and under floors. Your insurance company's adjuster only documents visible damage. They protect the company's profits, not your home.
          </p>
        </div>

        <div class="card-hover p-10">
          <h3 class="text-2xl font-bold text-[#082142] mb-6 flex items-center gap-3">
            <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-[#002D51]/10 text-[#00808C]">✓</span>
            Claim Guardians Uncovers the Truth.
          </h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">🔍</span><span class="text-lg font-medium text-[#082142]">Our experts use thermal imaging cameras.</span></li>
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">📸</span><span class="text-lg font-medium text-[#082142]">We document invisible moisture and structural rot.</span></li>
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">📝</span><span class="text-lg font-medium text-[#082142]">Claim Guardians estimates the true cost of complete restoration.</span></li>
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">⚖️</span><span class="text-lg font-medium text-[#082142]">Our team forces the insurance company to pay your maximum policy limit.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Urgency Alert -->
  <section class="section-dark text-center">
    <div class="section-inner">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-500/10 border border-red-500/20 text-4xl mb-8">🦠</div>
      <h2 class="section-heading-light mb-6 md:text-5xl">Standing Water Breeds Toxic Mold in <span class="text-red-400">48 Hours.</span></h2>
      <p class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl mx-auto">
        Delaying your claim reduces your payout. Florida's humidity accelerates mold growth. Claim Guardians dispatches an inspector immediately. <strong class="text-white">We protect your family's health and your financial rights.</strong>
      </p>
      <a href="tel:3058045489" class="btn-accent px-12 py-5 text-xl min-h-[64px]">Request Immediate Assistance</a>
    </div>
  </section>

  <!-- 4. Result Proof -->
  <section class="section-muted">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Proven Results</span>
        <h2 class="section-heading">Claim Guardians Secures Massive Water Damage Payouts.</h2>
      </div>

      <div class="max-w-3xl mx-auto card-testimonial">
        <span class="inline-flex px-4 py-2 bg-blue-50 text-[#002D51] text-sm font-bold rounded-full mb-8 border border-blue-100">📍 Kitchen Pipe Burst, Tampa, FL.</span>
        <div class="space-y-6 mb-8 pb-8 border-b border-slate-100">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
            <span class="text-slate-500 font-medium tracking-wide text-sm uppercase">Insurance Initial Offer</span>
            <span class="text-red-400 line-through font-bold text-2xl">$9,200 <span class="text-xs font-normal text-slate-400">(For "surface repairs")</span></span>
          </div>
          <div class="h-px w-full bg-gradient-to-r from-transparent via-slate-100 to-transparent"></div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
            <span class="text-[#082142] font-bold tracking-wide text-sm uppercase">Claim Guardians Settlement</span>
            <div>
              <span class="text-green-600 font-black text-4xl tracking-tighter">$68,400</span>
              <p class="text-xs font-medium text-green-700/70 uppercase tracking-wider mt-1">(For complete kitchen rebuild &amp; mitigation)</p>
            </div>
          </div>
        </div>
        <div class="bg-slate-50 -mx-10 -mb-10 p-10 rounded-b-3xl">
          <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Action Taken</h4>
          <p class="text-xl font-medium text-[#082142] leading-relaxed">
            Claim Guardians proved water damage destroyed the subfloor. We reversed the insurance company's lowball offer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Claim Value Calculator (BOFU Island) -->
  <section class="section-white overflow-hidden">
    <div class="section-inner">
      <div class="text-center mb-12">
        <span class="eyebrow">Water Damage Recovery</span>
        <h2 class="section-heading">Calculate Your True Payout <span class="text-[#00808C]">After a Leak.</span></h2>
      </div>
      <ClaimCalculator client:visible />
    </div>
  </section>


  <!-- 5. FAQs -->
  <section class="section-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="eyebrow">Common Questions</span>
        <h2 class="section-heading">Frequently Asked Questions About Water Damage Claims</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-white border border-slate-200 rounded-2xl [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#082142] group-hover:text-[#00808C] transition-colors">
            <span>Does homeowners insurance cover water damage in Florida?</span>
            <span class="transition group-open:rotate-180"><svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg></span>
          </summary>
          <div class="text-slate-600 px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4">
            Homeowners insurance covers sudden and accidental water damage, such as a burst pipe or broken water heater. However, insurers often deny claims citing "gradual wear and tear." Claim Guardians fights these unfair denials and secures your payout.
          </div>
        </details>
        <details class="group bg-white border border-slate-200 rounded-2xl [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#082142] group-hover:text-[#00808C] transition-colors">
            <span>Should I clean up the water before the adjuster arrives?</span>
            <span class="transition group-open:rotate-180"><svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg></span>
          </summary>
          <div class="text-slate-600 px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4">
            Stop the water source to prevent further destruction, but do not discard damaged items. Claim Guardians documents all ruined property to ensure the insurance company pays for your total loss.
          </div>
        </details>
        <details class="group bg-white border border-slate-200 rounded-2xl [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#082142] group-hover:text-[#00808C] transition-colors">
            <span>How much does a water damage public adjuster charge?</span>
            <span class="transition group-open:rotate-180"><svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg></span>
          </summary>
          <div class="text-slate-600 px-6 pb-6 text-lg leading-relaxed border-t border-slate-100 pt-4">
            Claim Guardians charges $0 for the initial property inspection. We work on a contingency basis — you pay a percentage only after we win your settlement.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Eligibility Test (BOFU Island) -->
  <section class="section-muted border-t border-slate-100">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Expert Audit</span>
        <h2 class="section-heading">Qualify Your Water Claim For <span class="text-[#00808C]">a 100% Free Review.</span></h2>
      </div>
      <EligibilityTest client:visible />
    </div>
  </section>

  <!-- 6. Service Area Link -->

  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <span class="eyebrow">Coverage</span>
      <h2 class="section-heading mb-4">Claim Guardians Serves All of Florida.</h2>
      <p class="text-lg text-slate-500 mb-8">From Miami to Jacksonville, our licensed public adjusters respond rapidly to your water emergency.</p>
      <a href="/service-areas" class="inline-flex items-center text-[#00808C] font-bold hover:text-[#002D51] transition-colors text-lg group">
        View All Florida Service Areas
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>

  <!-- Mobile Sticky CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-50 sm:hidden">
    <a href="tel:3058045489" class="btn-accent w-full text-lg">🚨 Emergency? Call Now</a>
  </div>

</BaseLayout>
