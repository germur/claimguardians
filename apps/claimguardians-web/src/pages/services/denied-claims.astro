---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimCalculator from '../../components/ClaimCalculator';
import EligibilityTest from '../../components/EligibilityTest';
---

<BaseLayout 
  title="Claim Guardians | Denied &amp; Underpaid Insurance Claims Florida" 
  description="Your insurance claim was denied or underpaid. Claim Guardians appeals the decision and forces your insurer to pay what you legally deserve in Florida."
>
  <!-- 1. Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-denied-claims.png" alt="Denied insurance claim on a Florida property" class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" loading="eager"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white" aria-current="page">Denied Claims</li>
        </ol>
      </nav>
      <div class="max-w-4xl">
        <span class="eyebrow" style="color:#00B5A6;">Property Damage — Denied &amp; Underpaid Claims</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians Appeals Your Denied Claim and Forces Full Payment.
        </h1>
        <p class="text-xl text-slate-300 mb-12 leading-relaxed max-w-3xl">
          A denied or underpaid claim is not the end. Claim Guardians investigates the insurer's reasoning, builds a forensic counter-argument, and forces your insurance company to reverse its decision. You pay nothing unless we win.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 mb-12">
          <a href="/free-claim-review" class="btn-accent px-10 py-5 text-lg min-h-[60px]">Get a Free Claim Appeal Review</a>
          <a href="tel:3058045489" class="inline-flex justify-center items-center px-10 py-5 text-lg font-bold text-white bg-white/5 border-2 border-white/20 rounded-xl hover:bg-white/10 transition-all transform hover:-translate-y-1 min-h-[60px]">Talk to an Expert Now</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 grayscale opacity-60">
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🏛️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">DFS Licensed</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🛡️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">Policyholder Advocacy</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">⚖️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">State Bonded</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">💰</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">No-Fee Guarantee</span>
        </div>
      </div>
      </div>
    </div>
  </header>

  <!-- 2. Why Claims Get Denied -->
  <section class="section-white">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Why Claims Get Denied</span>
        <h2 class="section-heading">The Most Common Insurance Denial Tactics in Florida.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card-hover group">
          <div class="text-4xl mb-4">📄</div>
          <h3 class="text-xl font-bold text-[#082142] mb-3 group-hover:text-[#00808C] transition-colors">"Pre-existing Condition"</h3>
          <p class="text-slate-500">Insurers claim damage existed before your policy. Claim Guardians documents the true cause and timeline of your loss.</p>
        </div>
        <div class="card-hover group">
          <div class="text-4xl mb-4">⏳</div>
          <h3 class="text-xl font-bold text-[#082142] mb-3 group-hover:text-[#00808C] transition-colors">"Late Filing"</h3>
          <p class="text-slate-500">Insurers deny claims citing missed deadlines. Claim Guardians reviews Florida statutes to challenge wrongful time-bar denials.</p>
        </div>
        <div class="card-hover group">
          <div class="text-4xl mb-4">📋</div>
          <h3 class="text-xl font-bold text-[#082142] mb-3 group-hover:text-[#00808C] transition-colors">"Policy Exclusion"</h3>
          <p class="text-slate-500">Complex policy language is used to exclude valid claims. Claim Guardians decodes your policy and identifies every applicable coverage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Result Proof -->
  <section class="section-muted">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Proven Results</span>
        <h2 class="section-heading">Denied Claims We Reversed into Full Payouts.</h2>
      </div>
      <div class="max-w-3xl mx-auto card-testimonial">
        <span class="inline-flex px-4 py-2 bg-blue-50 text-[#002D51] text-sm font-bold rounded-full mb-8 border border-blue-100">📍 Roof Storm Damage — "Pre-Existing Condition" Denial, Tampa, FL.</span>
        <div class="space-y-6 mb-8 pb-8 border-b border-slate-100">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
            <span class="text-slate-500 font-medium text-sm uppercase">Insurer's Decision</span>
            <span class="text-red-400 font-bold text-2xl">Full Denial</span>
          </div>
          <div class="h-px bg-slate-100"></div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
            <span class="text-[#082142] font-bold text-sm uppercase">Claim Guardians Settlement</span>
            <span class="text-green-600 font-black text-4xl tracking-tighter">$112,000</span>
          </div>
        </div>
        <div class="bg-slate-50 -mx-10 -mb-10 p-10 rounded-b-3xl">
          <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Action Taken</h4>
          <p class="text-xl font-medium text-[#082142] leading-relaxed">We commissioned a forensic engineering report proving the damage occurred during a specific storm event. The insurer reversed its denial and issued full payment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Claim Value Calculator (BOFU Island) -->
  <section class="section-white overflow-hidden">
    <div class="section-inner text-center">
      <div class="max-w-3xl mx-auto mb-12">
        <span class="eyebrow">Reversal Potential</span>
        <h2 class="section-heading">See How Much the Insurer <span class="text-red-500">Still Owes You.</span></h2>
      </div>
      <ClaimCalculator client:visible />
    </div>
  </section>


  <!-- 4. Final CTA -->
  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <span class="eyebrow">Appeals Audit</span>
      <h2 class="section-heading mb-4">Qualify Your Appeal in 30 Seconds.</h2>
      <EligibilityTest client:visible />
    </div>

  </section>

  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-50 sm:hidden">
    <a href="tel:3058045489" class="btn-accent w-full text-lg">🚨 Emergency? Call Now</a>
  </div>
</BaseLayout>
