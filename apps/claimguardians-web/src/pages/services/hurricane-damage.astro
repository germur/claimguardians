---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimCalculator from '../../components/ClaimCalculator';
import EligibilityTest from '../../components/EligibilityTest';
---

<BaseLayout 
  title="Claim Guardians | Hurricane &amp; Storm Damage Insurance Claims Florida" 
  description="Insurers minimize hurricane payouts. Claim Guardians forces them to cover full wind, hail, and structural damage across Florida. Zero upfront fees."
>
  <!-- 1. Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-hurricane-damage.png" alt="Hurricane storm damage to Florida neighborhood" class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" loading="eager"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white" aria-current="page">Hurricane Damage</li>
        </ol>
      </nav>
      <div class="max-w-4xl">
        <span class="eyebrow" style="color:#00B5A6;">Property Damage — Hurricane &amp; Storm</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians Maximizes Your Hurricane Damage Insurance Claim.
        </h1>
        <p class="text-xl text-slate-300 mb-12 leading-relaxed max-w-3xl">
          Hurricane season devastates Florida properties. Insurance companies minimize payouts by disputing wind damage and storm surge. Claim Guardians forces your insurer to pay the full cost of your hurricane recovery.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 mb-12">
          <a href="/free-claim-review" class="btn-accent px-10 py-5 text-lg min-h-[60px]">Get a Free Hurricane Damage Inspection</a>
          <a href="tel:3058045489" class="inline-flex justify-center items-center px-10 py-5 text-lg font-bold text-white bg-white/5 border-2 border-white/20 rounded-xl hover:bg-white/10 transition-all transform hover:-translate-y-1 min-h-[60px]">Call a Storm Expert Now</a>
        </div>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-4 pt-6 border-t border-white/10">
          <div class="flex items-center gap-2 text-slate-300 font-semibold text-sm"><span class="text-[#00B5A6]">✓</span> Florida DFS Licensed</div>
          <div class="flex items-center gap-2 text-slate-300 font-semibold text-sm"><span class="text-[#00B5A6]">✓</span> No Recovery, No Fee</div>
          <div class="flex items-center gap-2 text-slate-300 font-semibold text-sm"><span class="text-[#00B5A6]">✓</span> Catastrophic Loss Specialists</div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. Problem / Solution -->
  <section class="section-white">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <span class="eyebrow">The Problem</span>
          <h2 class="section-heading mb-6">Insurers Dispute Wind and Surge Damage to Protect Profits.</h2>
          <p class="text-lg text-slate-500 leading-relaxed">
            After a hurricane, insurance adjusters rush inspections. They classify wind damage as "pre-existing wear" and dispute storm surge as a "flood" (often excluded from standard policies). Your settlement suffers.
          </p>
        </div>
        <div class="card-hover p-10">
          <h3 class="text-2xl font-bold text-[#082142] mb-6 flex items-center gap-3">
            <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-[#002D51]/10 text-[#00808C]">✓</span>
            Claim Guardians Fights for Every Dollar.
          </h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">🌀</span><span class="text-lg font-medium text-[#082142]">We document all wind uplift, flying debris, and structural failures.</span></li>
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">🏗️</span><span class="text-lg font-medium text-[#082142]">We source licensed contractor estimates for full rebuilds.</span></li>
            <li class="flex items-start gap-4"><span class="text-[#00808C] mt-1">⚖️</span><span class="text-lg font-medium text-[#082142]">We force your insurer to honor the total policy value for catastrophic losses.</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Result Proof -->
  <section class="section-muted">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Proven Results</span>
        <h2 class="section-heading">We Turn Denied Claims into Full Payouts.</h2>
      </div>
      <div class="max-w-3xl mx-auto card-testimonial">
        <span class="inline-flex px-4 py-2 bg-blue-50 text-[#002D51] text-sm font-bold rounded-full mb-8 border border-blue-100">📍 Hurricane Ian Roof &amp; Structural Damage, Fort Myers, FL.</span>
        <div class="space-y-6 mb-8 pb-8 border-b border-slate-100">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
            <span class="text-slate-500 font-medium text-sm uppercase">Insurance Initial Offer</span>
            <span class="text-red-400 line-through font-bold text-2xl">$31,000</span>
          </div>
          <div class="h-px w-full bg-gradient-to-r from-transparent via-slate-100 to-transparent"></div>
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
            <span class="text-[#082142] font-bold text-sm uppercase">Claim Guardians Settlement</span>
            <span class="text-green-600 font-black text-4xl tracking-tighter">$198,500</span>
          </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 grayscale opacity-60">
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🏛️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">DFS Licensed</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">🛡️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">Policyholder Advocacy</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">⚖️</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">State Bonded</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-2xl">💰</span>
          <span class="text-[10px] uppercase font-black tracking-widest text-slate-400">No-Fee Guarantee</span>
        </div>
      </div>
        <div class="bg-slate-50 -mx-10 -mb-10 p-10 rounded-b-3xl">
          <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-3">Action Taken</h4>
          <p class="text-xl font-medium text-[#082142] leading-relaxed">We documented full structural displacement and forced coverage for complete rebuild under Florida's Valued Policy Law.</p>
        </div>
      </div>

      <div class="mt-24 max-w-4xl mx-auto">
        <ClaimCalculator client:visible />
      </div>
    </div>
  </section>

  <section class="section-white border-t border-slate-100">
     <div class="section-inner">
       <div class="text-center mb-16">
         <span class="eyebrow">Storm Damage Review</span>
         <h2 class="section-heading">Qualify Your Hurricane Claim For <span class="text-[#00808C]">a Legal Audit.</span></h2>
       </div>
       <EligibilityTest client:visible />
     </div>
  </section>

  <!-- 4. Final CTA -->
  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <span class="eyebrow">No-Risk Consultation</span>
      <h2 class="section-heading mb-4">Did a Hurricane Damage Your Florida Property?</h2>
      <p class="text-xl text-slate-500 mb-8 max-w-2xl mx-auto">Don't settle for what the insurance company offers. Get the maximum payout you're legally owed.</p>
      <a href="/free-claim-review" class="btn-accent px-12 py-5 text-xl min-h-[64px]">Start Free Hurricane Claim Review →</a>
      <p class="text-sm text-slate-400 mt-4">Zero upfront cost. Ever.</p>
    </div>
  </section>

  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-10px_40px_rgba(0,0,0,0.1)] z-50 sm:hidden">
    <a href="tel:3058045489" class="btn-accent w-full text-lg">🚨 Emergency? Call Now</a>
  </div>
</BaseLayout>
