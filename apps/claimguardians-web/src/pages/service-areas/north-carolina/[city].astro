const { data } = Astro.props;
const { city, slug, county, localRisk, zipCodes, nearbyAreas, damageAngles, caseStudies, faq } = data;
---

<MinimalAdLayout
  title={`Public Adjuster in ${city}, NC | Claim Guardians`}
  description={`Property damage in ${city}? Claim Guardians' NC-licensed public adjusters handle your insurance claim from inspection to settlement. No recovery, no fee.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": `Claim Guardians - ${city}, NC`,
      "image": "https://allclaimguardians.com/images/logo-color.svg",
      "telephone": "(305) 804-5489",
      "url": `https://allclaimguardians.com/service-areas/north-carolina/${slug}`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": city,
        "addressRegion": "NC",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": county
      },
      "makesOffer": {
        "@type": "Offer",
        "description": `Public adjusting services for ${localRisk} claims in ${county}`,
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "0",
          "priceCurrency": "USD",
          "description": "No upfront cost - contingency fee only"
        }
      },
      "description": `Licensed public adjusters serving ${city}, NC and all of ${county}. Specializing in ${localRisk} damage claims.`
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://allclaimguardians.com/" },
        { "@type": "ListItem", "position": 2, "name": "Service Areas", "item": "https://allclaimguardians.com/service-areas/" },
        { "@type": "ListItem", "position": 3, "name": "North Carolina", "item": "https://allclaimguardians.com/service-areas/north-carolina/" },
        { "@type": "ListItem", "position": 4, "name": city, "item": `https://allclaimguardians.com/service-areas/north-carolina/${slug}/` }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": `Public Adjusting Services in ${city}, NC`,
      "provider": { "@type": "LocalBusiness", "name": "Claim Guardians LLC" },
      "areaServed": { "@type": "AdministrativeArea", "name": county },
      "description": `Licensed public adjusters handling ${localRisk} damage claims in ${city} and ${county}.`,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free inspection. No recovery, no fee." }
    })} />
  </Fragment>

  <!-- 1. HERO -->
  <section class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/florida-damaged-house-hero.png" alt={`Property damage in ${city}, North Carolina`} class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/service-areas" class="hover:text-white transition-colors">Service Areas</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/service-areas/north-carolina" class="hover:text-white transition-colors">North Carolina</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white" aria-current="page">{city}</li>
        </ol>
      </nav>
      <div class="max-w-4xl">
