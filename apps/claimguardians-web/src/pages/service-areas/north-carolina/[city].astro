    <div class="section-inner">
      <div class="max-w-3xl mb-16">
        <span class="eyebrow">Full service</span>
        <h2 class="section-heading mb-4">Every Type of Property Damage Claim in {city}.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/services/water-damage/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">💧</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Water & Leak Damage</h3>
