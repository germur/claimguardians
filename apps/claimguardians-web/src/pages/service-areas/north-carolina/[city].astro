          <p class="text-slate-500 font-medium leading-relaxed">{damageAngles.primaryDesc}</p>
          <a href="/services/hurricane-damage/" class="inline-flex items-center gap-2 mt-4 text-sm font-bold text-[#00808C] hover:text-[#002D51] transition-colors">Learn about our storm claim process →</a>
        </div>
        <div class="card-hover p-8">
          <div class="text-3xl mb-4">💧</div>
