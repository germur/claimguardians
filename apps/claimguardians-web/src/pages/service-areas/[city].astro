---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const floridaCities = [
    { city: "Miami", county: "Miami-Dade County", localRisk: "hurricane and flood", zipCodes: ["33101", "33129", "33132"] },
    { city: "Fort Lauderdale", county: "Broward County", localRisk: "hurricane and severe storm", zipCodes: ["33301", "33304", "33316"] },
    { city: "West Palm Beach", county: "Palm Beach County", localRisk: "windstorm and hurricane", zipCodes: ["33401", "33405", "33409"] },
    { city: "Boca Raton", county: "Palm Beach County", localRisk: "storm and water", zipCodes: ["33431", "33432", "33486"] },
    { city: "Orlando", county: "Orange County", localRisk: "tornado and sinkhole", zipCodes: ["32801", "32803", "32804"] },
    { city: "Tampa", county: "Hillsborough County", localRisk: "flood and severe storm", zipCodes: ["33602", "33606", "33609"] },
    { city: "Fort Myers", county: "Lee County", localRisk: "catastrophic hurricane and storm surge", zipCodes: ["33901", "33916", "33919"] },
    { city: "Naples", county: "Collier County", localRisk: "hurricane and wind", zipCodes: ["34102", "34103", "34105"] },
    { city: "Jacksonville", county: "Duval County", localRisk: "windstorm and flood", zipCodes: ["32202", "32204", "32207"] }
  ];

  return floridaCities.map((data) => ({
    params: { city: data.city.toLowerCase().replace(/\s+/g, '-') },
    props: { data },
  }));
}

const { data } = Astro.props;
const { city, county, localRisk, zipCodes } = data;
---

<BaseLayout 
  title={`Public Adjuster in ${city}, FL | Claim Guardians`}
  description={`Claim Guardians maximizes property damage settlements in ${city}, ${county}. We handle ${localRisk} claims for local homeowners and businesses.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": `Claim Guardians - ${city}`,
      "image": "https://www.claimguardians.com/images/logo-color.svg",
      "telephone": "(305) 804-5489",
      "url": `https://www.claimguardians.com/service-areas/${city.toLowerCase().replace(/\s+/g, '-')}`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": city,
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "description": `${city}, ${county}, Florida`
        },
        "geoRadius": "50000"
      },
      "makesOffer": zipCodes.map(zip => ({
        "@type": "Offer",
        "eligibleRegion": { "@type": "PostalCode", "postalCode": zip }
      })),
      "description": `Public Adjusting firm serving ${county}, specializing in ${localRisk} damage claims.`
    })} />
  </Fragment>

  <!-- 1. Localized Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-city-florida.png" alt={`${city}, Florida — Claim Guardians service area`} class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" loading="eager"/>
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li><a href="/service-areas" class="hover:text-white transition-colors">Service Areas</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white" aria-current="page">{city}</li>
        </ol>
      </nav>

      <div class="max-w-4xl">
        <span class="eyebrow" style="color:#00B5A6;">Public Adjuster — {county}</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians Maximizes Your Property Claim in {city}, FL.
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-3xl">
          Claim Guardians evaluates <strong class="text-white">{localRisk}</strong> damage for properties across {county}. Our local public adjusters force your insurance company to pay what you legally deserve.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-5 mb-14">
          <a href="/free-claim-review" class="btn-accent px-10 py-5 text-lg min-h-[60px]">
            Free {city} Property Inspection
          </a>
          <a href="tel:3058045489" class="inline-flex justify-center items-center px-10 py-5 text-lg font-bold text-white bg-white/5 backdrop-blur-md border-2 border-white/20 rounded-xl hover:bg-white/10 transition-all duration-300 transform hover:-translate-y-1 min-h-[60px]">
            Call a Local Expert
          </a>
        </div>
        
        <!-- Trust Bar -->
        <div class="flex flex-wrap items-center gap-x-10 gap-y-4 pt-6 border-t border-white/10">
          <div class="flex items-center gap-3 text-slate-300 font-semibold text-sm">
            <span class="text-[#00B5A6]">✓</span> Serving all of {county}
          </div>
          <div class="flex items-center gap-3 text-slate-300 font-semibold text-sm">
            <span class="text-[#00B5A6]">✓</span> Florida DFS Licensed
          </div>
          <div class="flex items-center gap-3 text-slate-300 font-semibold text-sm">
            <span class="text-[#00B5A6]">✓</span> No Recovery, No Fee
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. Localized Problem / Solution -->
  <section class="section-white">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Problem -->
        <div>
          <span class="eyebrow">The Problem</span>
          <h2 class="section-heading mb-6">Insurance Companies Routinely Underpay {city} Residents.</h2>
          <p class="text-lg text-slate-500 leading-relaxed mb-4">
            Due to the high frequency of <strong class="text-[#082142]">{localRisk}</strong> in {county}, insurance adjusters are trained to minimize payouts. They blame damage on "pre-existing conditions" to protect corporate profits.
          </p>
          <p class="text-lg text-slate-500 leading-relaxed">
            You need a local advocate who understands the building codes and weather patterns of the {city} area.
          </p>
        </div>

        <!-- Solution -->
        <div class="card-hover p-10">
          <h3 class="text-2xl font-bold text-[#082142] mb-6 flex items-center gap-3">
            <span class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-[#002D51]/10 text-[#00808C]">✓</span>
            We Represent Policyholders in {city}.
          </h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <span class="text-[#00808C] mt-1 flex-shrink-0">📍</span>
              <span class="text-lg font-medium text-[#082142]">Local presence ensuring rapid dispatch to any address in {county}.</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="text-[#00808C] mt-1 flex-shrink-0">🔍</span>
              <span class="text-lg font-medium text-[#082142]">Mastery of {city} municipal building codes to enforce compliance upgrades.</span>
            </li>
            <li class="flex items-start gap-4">
              <span class="text-[#00808C] mt-1 flex-shrink-0">⚖️</span>
              <span class="text-lg font-medium text-[#082142]">We aggressively negotiate until your insurer pays the true cost of local repair.</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. Local Coverage Zip Codes -->
  <section class="section-muted text-center">
    <div class="section-inner">
      <span class="eyebrow">Coverage Zones</span>
      <h2 class="section-heading mb-4">Dedicated Coverage Across {county}</h2>
      <p class="text-lg text-slate-500 mb-12 max-w-2xl mx-auto">
        Our {city} field adjusters are actively responding to claims in the following primary zip codes, and all surrounding neighborhoods.
      </p>
      
      <div class="flex flex-wrap justify-center gap-4">
        {zipCodes.map((zip) => (
          <div class="px-6 py-3 bg-white border border-slate-200 rounded-full shadow-sm text-lg font-bold text-[#002D51]">
            {zip}
          </div>
        ))}
        <div class="px-6 py-3 bg-white border border-slate-200 rounded-full shadow-sm text-lg font-bold text-slate-400">
          + All surrounding areas
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA -->
  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <span class="eyebrow">No-Risk Consultation</span>
      <h2 class="section-heading mb-4">Was Your {city} Property Damaged?</h2>
      <p class="text-xl text-slate-500 mb-8 max-w-2xl mx-auto leading-relaxed">
        Don't let the insurance company dictate the outcome of your claim. Get a free, expert settlement review today.
      </p>
      <a href="/free-claim-review" class="btn-accent px-12 py-5 text-xl min-h-[64px]">
        Request Free Case Review →
      </a>
      <p class="text-sm text-slate-400 mt-4">Zero upfront cost. Ever.</p>
    </div>
  </section>

</BaseLayout>
