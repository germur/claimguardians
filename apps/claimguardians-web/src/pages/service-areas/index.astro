---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Claim Guardians | Florida & California Public Adjuster Service Areas" 
  description="Severe weather destroys homes and businesses across Florida and California. Our local public adjusters respond rapidly to your location."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "Does Claim Guardians cover my specific county in Florida?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Claim Guardians serves all 67 counties in Florida. We maintain a network of licensed adjusters across the state. We dispatch an expert to your property within 24 hours of your call."
          }
        }, {
          "@type": "Question",
          "name": "Can an out-of-state adjuster handle my Florida claim?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Florida law requires public adjusters to hold a specific state license. Claim Guardians strictly employs Florida-licensed adjusters. We protect you from illegal, out-of-state operators."
          }
        }]
      }
    </script>
  </Fragment>

  <!-- 1. Hero Section -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-city-florida.png" alt="Florida skyline - Claim Guardians service areas" class="w-full h-full object-cover opacity-60 scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    
    <div class="section-inner relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white font-bold" aria-current="page">Service Areas</li>
        </ol>
      </nav>

      <div class="max-w-4xl mx-auto">
        <span class="eyebrow" style="color:#00B5A6;">Local Advocacy</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00808C] to-[#00B5A6]">Serves Property Owners</span> Across Florida & California.
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed font-medium">
          From coastal hurricanes to western wildfires, our licensed adjusters respond rapidly to evaluate your property damage and force insurers to pay.
        </p>
      </div>
    </div>
  </header>

  <!-- 2. Top Service Areas Grid -->
  <section class="section-white" style="margin-top:-4rem;">
    <div class="section-inner relative z-20">
      <div class="text-center mb-16">
        <h2 class="section-heading">We Dispatch Experts to Your City.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- South Florida -->
        <div class="card-hover p-10 group">
          <h3 class="text-2xl font-black text-[#082142] mb-8 flex items-center gap-3">
            <span class="text-3xl">🌴</span> South Florida
          </h3>
          <ul class="space-y-4">
            <li><a href="/service-areas/miami" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Miami</a></li>
            <li><a href="/service-areas/fort-lauderdale" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Fort Lauderdale</a></li>
            <li><a href="/service-areas/west-palm-beach" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">West Palm Beach</a></li>
            <li><a href="/service-areas/boca-raton" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Boca Raton</a></li>
          </ul>
        </div>

        <!-- Central Florida -->
        <div class="card-hover p-10 group">
          <h3 class="text-2xl font-black text-[#082142] mb-8 flex items-center gap-3">
            <span class="text-3xl">🎢</span> Central Florida
          </h3>
          <ul class="space-y-4">
            <li><a href="/service-areas/orlando" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Orlando</a></li>
            <li><a href="/service-areas/kissimmee" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Kissimmee</a></li>
            <li><a href="/service-areas/daytona-beach" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Daytona Beach</a></li>
            <li><a href="/service-areas/lakeland" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Lakeland</a></li>
          </ul>
        </div>

        <!-- West Coast -->
        <div class="card-hover p-10 group">
          <h3 class="text-2xl font-black text-[#082142] mb-8 flex items-center gap-3">
            <span class="text-3xl">🌅</span> West Coast FL
          </h3>
          <ul class="space-y-4">
            <li><a href="/service-areas/tampa" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Tampa</a></li>
            <li><a href="/service-areas/fort-myers" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Fort Myers</a></li>
            <li><a href="/service-areas/cape-coral" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Cape Coral</a></li>
            <li><a href="/service-areas/naples" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Naples</a></li>
          </ul>
        </div>

        <!-- California -->
        <div class="card-hover p-10 group bg-slate-50 ring-1 ring-[#00B5A6]/20">
          <h3 class="text-2xl font-black text-[#082142] mb-8 flex items-center gap-3">
            <span class="text-3xl">🐻</span> California
          </h3>
          <ul class="space-y-4">
            <li><a href="/service-areas/los-angeles" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Los Angeles</a></li>
            <li><a href="/service-areas/san-francisco" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">San Francisco</a></li>
            <li><a href="/service-areas/san-diego" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">San Diego</a></li>
            <li><a href="/service-areas/sacramento" class="text-lg font-bold text-slate-500 hover:text-[#00808C] transition-colors flex items-center gap-2">Sacramento</a></li>
          </ul>
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="tel:3058045489" class="btn-accent text-xl px-12 py-5 rounded-2xl">
          Don't see your city? Call us now.
        </a>
      </div>
    </div>
  </section>

  <!-- 3. Local Expertise Mapping -->
  <section class="section-muted border-y border-slate-200">
    <div class="section-inner text-center">
      <span class="eyebrow">State-Wide Presence</span>
      <h2 class="section-heading mb-12">Serving Florida & California.</h2>
      
      <div class="max-w-4xl mx-auto">
        <div class="card-hover bg-white p-12">
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
            <li class="flex items-center gap-4 text-xl font-bold text-[#082142]">
              <span class="text-[#00B5A6]">✓</span> Licensed Adjusters Homegrown in FL & CA
            </li>
            <li class="flex items-center gap-4 text-xl font-bold text-[#082142]">
              <span class="text-[#00B5A6]">✓</span> Expert Knowledge of Local Codes
            </li>
            <li class="flex items-center gap-4 text-xl font-bold text-[#082142]">
              <span class="text-[#00B5A6]">✓</span> Rapid On-Site Inspections Within 24h
            </li>
            <li class="flex items-center gap-4 text-xl font-bold text-[#082142]">
              <span class="text-[#00B5A6]">✓</span> From the FL Keys to the CA Coast
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. FAQ -->
  <section class="section-white">
    <div class="section-inner max-w-4xl mx-auto">
      <h2 class="section-heading text-center mb-12">Service Area FAQs</h2>
      <div class="space-y-6">
        <div class="bg-white rounded-3xl p-10 border-2 border-slate-100 shadow-sm">
          <h3 class="text-2xl font-black text-[#082142] mb-4">Does Claim Guardians cover my specific county?</h3>
          <p class="text-lg text-slate-500 font-medium">Yes. Claim Guardians serves all 67 counties in Florida. We maintain a network of licensed adjusters across the state to ensure rapid dispatch to any loss location.</p>
        </div>
        <div class="bg-white rounded-3xl p-10 border-2 border-slate-100 shadow-sm">
          <h3 class="text-2xl font-black text-[#082142] mb-4">Can an out-of-state adjuster handle my claim?</h3>
          <p class="text-lg text-slate-500 font-medium">Florida law requires public adjusters to hold a specific state license. Claim Guardians strictly employs Florida-licensed adjusters to protect you from illegal, out-of-state operators.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
