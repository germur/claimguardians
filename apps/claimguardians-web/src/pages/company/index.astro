---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
---

<BaseLayout 
  title="About Claim Guardians | Licensed Public Adjusters in NC, FL & CA"
  description="Meet the team behind Claim Guardians. Licensed public adjusters in North Carolina, Florida & California with a proven track record of maximizing insurance settlements."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "mainEntity": {
          "@type": "Organization",
          "name": "Claim Guardians LLC",
          "url": "https://allclaimguardians.com",
          "telephone": "(305) 804-5489",
          "areaServed": ["North Carolina", "Florida", "California"],
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "304 Indian Trace Unit 655",
            "addressLocality": "Weston",
            "addressRegion": "FL",
            "postalCode": "33326",
            "addressCountry": "US"
          },
          "member": [
            {
              "@type": "Person",
              "name": "Alejandro Sibila",
              "jobTitle": "Principal Public Adjuster",
              "description": "State Licensed Public Adjuster in North Carolina, Florida, and California",
              "knowsAbout": ["Public Adjusting", "Property Insurance Claims", "Hurricane Damage", "Water Damage", "Fire Damage"]
            }
          ],
          "hasCredential": [
            { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "Florida DFS Public Adjuster License", "recognizedBy": { "@type": "Organization", "name": "Florida Department of Financial Services" } },
            { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "North Carolina DOI Public Adjuster License", "recognizedBy": { "@type": "Organization", "name": "North Carolina Department of Insurance" } },
            { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "California DOI Public Adjuster License", "recognizedBy": { "@type": "Organization", "name": "California Department of Insurance" } }
          ]
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "What is a public adjuster?", "acceptedAnswer": { "@type": "Answer", "text": "A public adjuster is a licensed insurance professional who works exclusively for policyholders — not the insurance company. We inspect damage, document claims, and negotiate directly with your insurer to maximize your settlement." } },
          { "@type": "Question", "name": "How is a public adjuster different from my insurance company's adjuster?", "acceptedAnswer": { "@type": "Answer", "text": "Your insurance company's adjuster works for them and is incentivized to minimize your payout. A public adjuster works exclusively for you and is incentivized to maximize your settlement. Studies show policyholders who use public adjusters recover significantly more." } },
          { "@type": "Question", "name": "What states is Claim Guardians licensed in?", "acceptedAnswer": { "@type": "Answer", "text": "Claim Guardians holds active public adjuster licenses in North Carolina, Florida, and California. Our team is regulated by each state's Department of Insurance and bonded in all three states." } },
          { "@type": "Question", "name": "How much does Claim Guardians charge?", "acceptedAnswer": { "@type": "Answer", "text": "Zero upfront. We work on a contingency fee basis — a state-regulated percentage collected only after you receive your settlement check. If we don't recover anything for you, you pay nothing." } }
        ]
      }
    </script>
  </Fragment>

  <!-- 1. Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <Image src="/images/hero-team-adjusters.png" width={1920} height={1080} alt="Claim Guardians public adjusters team" class="w-full h-full object-cover opacity-60 scale-105" fetchpriority="high" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    <div class="section-inner relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white font-bold" aria-current="page">Company</li>
        </ol>
      </nav>
      <div class="max-w-4xl mx-auto">
        <span class="eyebrow" style="color:#00B5A6;">The Advocacy Firm</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00808C] to-[#00B5A6]">Fights the Insurance Giants</span> For You.
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed font-medium">
          Insurance corporations employ armies of adjusters to protect their profits. We work exclusively for property owners — in North Carolina, Florida, and California — to protect your financial future.
        </p>
      </div>
    </div>
  </header>

  <!-- 2. No-Recovery No-Fee Guarantee -->
  <section class="section-white" style="margin-top: -4rem;">
    <div class="section-inner relative z-20">
      <div class="card-hover p-1 md:p-1.5 shadow-2xl">
        <div class="bg-white rounded-[22px] md:rounded-[20px] p-10 md:p-16 relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-12 items-center">
            <div class="md:w-1/3 text-center md:text-left">
              <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-blue-50 text-4xl mb-6 border border-blue-100 shadow-inner">🛡️</div>
              <h2 class="text-3xl font-extrabold text-[#082142] leading-tight mb-4">
                The Claim Guardians <br/><span class="text-[#00808C]">No-Recovery, No-Fee</span> Promise.
              </h2>
            </div>
            <div class="md:w-2/3">
              <ul class="space-y-6">
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">We charge $0 for your initial property inspection.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">You pay zero out-of-pocket costs during the process.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">We advance all costs for experts, documentation, and engineering reports.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">We collect a state-regulated percentage ONLY after you receive your check.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Licenses & Credentials (EEAT) -->
  <section class="section-muted border-y border-slate-200">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Proven Authority</span>
        <h2 class="section-heading mb-4">State-Licensed in Three States. Regulated. Bonded.</h2>
        <p class="text-xl text-slate-500 leading-relaxed max-w-3xl mx-auto font-medium">
          Every state strictly regulates public adjusters to protect consumers. Claim Guardians holds active licenses from three state Departments of Insurance. We are legally bound to act in YOUR best interest.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="card-hover p-10 text-center">
          <div class="text-4xl mb-4">🏛️</div>
          <h3 class="text-xl font-extrabold text-[#082142] mb-2">North Carolina</h3>
          <p class="text-sm text-slate-500 font-medium mb-4">NC Department of Insurance</p>
          <div class="inline-block px-4 py-2 bg-slate-50 text-slate-600 text-xs font-black rounded-full border border-slate-100">NC DOI LICENSED</div>
          <p class="text-sm text-slate-400 mt-4">Serving Charlotte, Raleigh, Wilmington, Asheville, and all NC counties</p>
        </div>
        <div class="card-hover p-10 text-center">
          <div class="text-4xl mb-4">🏛️</div>
          <h3 class="text-xl font-extrabold text-[#082142] mb-2">Florida</h3>
          <p class="text-sm text-slate-500 font-medium mb-4">FL Department of Financial Services</p>
          <div class="inline-block px-4 py-2 bg-slate-50 text-slate-600 text-xs font-black rounded-full border border-slate-100">FL DFS LICENSE # W116187</div>
          <p class="text-sm text-slate-400 mt-4">Serving Miami, Tampa, Orlando, Fort Lauderdale, and all FL counties</p>
        </div>
        <div class="card-hover p-10 text-center">
          <div class="text-4xl mb-4">🏛️</div>
          <h3 class="text-xl font-extrabold text-[#082142] mb-2">California</h3>
          <p class="text-sm text-slate-500 font-medium mb-4">CA Department of Insurance</p>
          <div class="inline-block px-4 py-2 bg-slate-50 text-slate-600 text-xs font-black rounded-full border border-slate-100">CA DOI LICENSED</div>
          <p class="text-sm text-slate-400 mt-4">Serving Los Angeles, San Diego, Sacramento, San Francisco, and all CA counties</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. The Team -->
  <section class="section-white">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Your Guardians</span>
        <h2 class="section-heading mb-4">The Team Behind Your Settlement.</h2>
        <p class="text-lg text-slate-500 font-medium max-w-2xl mx-auto">Every member of our team is a licensed, experienced insurance professional dedicated to one thing: getting you the maximum settlement your policy allows.</p>
      </div>
      <div class="grid grid-cols-1 gap-12 max-w-lg mx-auto">
        <div class="card-testimonial text-center group">
          <div class="w-40 h-40 mx-auto bg-slate-100 rounded-full mb-8 relative overflow-hidden border-4 border-white shadow-2xl group-hover:scale-105 transition-transform">
            <div class="absolute inset-0 flex items-center justify-center text-5xl opacity-20 grayscale">👤</div>
          </div>
          <h3 class="text-2xl font-black text-[#082142] mb-1">Alejandro Sibila</h3>
          <p class="text-[#00808C] font-black text-sm uppercase tracking-widest mb-4">Principal Public Adjuster</p>
          <p class="text-slate-500 font-medium text-sm leading-relaxed max-w-sm mx-auto mb-6">
            Licensed in North Carolina, Florida, and California. Specializes in hurricane damage, water damage, and complex denied claims. Has recovered millions for property owners across three states.
          </p>
          <div class="flex flex-col gap-2 items-center">
            <div class="inline-block px-5 py-2 bg-slate-50 text-slate-500 text-xs font-black rounded-full border border-slate-100 tracking-tighter">FL LICENSE # W116187</div>
            <div class="flex gap-2 flex-wrap justify-center">
              <div class="inline-block px-4 py-1.5 bg-slate-50 text-slate-400 text-[10px] font-black rounded-full border border-slate-100 tracking-tighter">NC LICENSED</div>
              <div class="inline-block px-4 py-1.5 bg-slate-50 text-slate-400 text-[10px] font-black rounded-full border border-slate-100 tracking-tighter">FL LICENSED</div>
              <div class="inline-block px-4 py-1.5 bg-slate-50 text-slate-400 text-[10px] font-black rounded-full border border-slate-100 tracking-tighter">CA LICENSED</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. What We Handle -->
  <section class="section-muted">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Our expertise</span>
        <h2 class="section-heading mb-4">Every Type of Property Damage Claim.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/services/water-damage/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">💧</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Water & Leak Damage</h3>
              <p class="text-sm text-slate-500 font-medium">Pipe bursts, hidden moisture, flooding</p>
            </div>
          </div>
        </a>
        <a href="/services/hurricane-damage/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">🌪️</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Hurricane & Storm</h3>
              <p class="text-sm text-slate-500 font-medium">Wind, hail, tropical storm damage</p>
            </div>
          </div>
        </a>
        <a href="/services/roof-damage/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">🏠</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Roof Damage</h3>
              <p class="text-sm text-slate-500 font-medium">Structural failures, hail, leaks</p>
            </div>
          </div>
        </a>
        <a href="/services/fire-damage/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">🔥</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Fire & Smoke</h3>
              <p class="text-sm text-slate-500 font-medium">Structural loss, smoke assessment</p>
            </div>
          </div>
        </a>
        <a href="/services/mold-claims/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">🦠</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Mold Damage</h3>
              <p class="text-sm text-slate-500 font-medium">Post-water exposure mold claims</p>
            </div>
          </div>
        </a>
        <a href="/services/denied-claims/" class="card-hover p-6 block group">
          <div class="flex items-center gap-4">
            <span class="text-2xl">⚖️</span>
            <div>
              <h3 class="text-lg font-extrabold text-[#082142] group-hover:text-[#00808C] transition-colors">Denied & Underpaid</h3>
              <p class="text-sm text-slate-500 font-medium">Appeals and forced full payment</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section class="section-white">
    <div class="section-inner max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">Common questions</span>
        <h2 class="section-heading">About Public Adjusters and Claim Guardians.</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <summary class="flex justify-between items-center px-8 py-6 cursor-pointer font-bold text-[#082142] text-lg hover:bg-slate-50 transition-colors"><span>What is a public adjuster?</span><svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></summary>
          <div class="px-8 pb-6 text-slate-500 font-medium leading-relaxed">A public adjuster is a licensed insurance professional who works exclusively for policyholders — not the insurance company. We inspect your property damage, document your claim with professional equipment, and negotiate directly with your insurer to maximize your settlement. Unlike the adjuster your insurance company sends (who works for them), we work for you.</div>
        </details>
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <summary class="flex justify-between items-center px-8 py-6 cursor-pointer font-bold text-[#082142] text-lg hover:bg-slate-50 transition-colors"><span>How is a public adjuster different from my insurance company's adjuster?</span><svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></summary>
          <div class="px-8 pb-6 text-slate-500 font-medium leading-relaxed">Your insurance company's adjuster is employed by your insurer and incentivized to minimize your payout. A public adjuster is hired by you, licensed by the state, and incentivized to maximize your settlement. Research consistently shows that policyholders who use public adjusters recover significantly more than those who don't.</div>
        </details>
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <summary class="flex justify-between items-center px-8 py-6 cursor-pointer font-bold text-[#082142] text-lg hover:bg-slate-50 transition-colors"><span>What states is Claim Guardians licensed in?</span><svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></summary>
          <div class="px-8 pb-6 text-slate-500 font-medium leading-relaxed">Claim Guardians holds active public adjuster licenses in North Carolina, Florida, and California. Our team is regulated by each state's Department of Insurance and bonded in all three states. We serve all cities and counties within NC, FL, and CA.</div>
        </details>
        <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <summary class="flex justify-between items-center px-8 py-6 cursor-pointer font-bold text-[#082142] text-lg hover:bg-slate-50 transition-colors"><span>How much does Claim Guardians charge?</span><svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></summary>
          <div class="px-8 pb-6 text-slate-500 font-medium leading-relaxed">Zero upfront. We work on a contingency fee basis — a state-regulated percentage collected only after you receive your settlement check. We advance all costs for inspections, documentation, engineering reports, and expert opinions. If we don't recover anything for you, you pay nothing. Period.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- 7. Final CTA -->
  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <h2 class="section-heading mb-6">Stop Fighting Your Insurance Company Alone.</h2>
      <p class="text-xl text-slate-500 mb-10 font-medium max-w-2xl mx-auto leading-relaxed">
        Claim Guardians takes over the stress today. We focus on the policy so you can focus on your recovery.
      </p>
      <a href="/free-claim-review" class="btn-accent px-12 py-5 text-2xl min-h-[64px]">Get Your Free Claim Review →</a>
      <p class="text-sm text-slate-400 mt-4">Zero upfront cost. Guaranteed.</p>
    </div>
  </section>

</BaseLayout>
