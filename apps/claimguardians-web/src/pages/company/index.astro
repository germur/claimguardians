---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Claim Guardians | Company & EEAT Credentials" 
  description="We work exclusively for property owners to protect your financial future. Florida-licensed, DFS-regulated public adjusters."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "mainEntity": {
          "@type": "Organization",
          "name": "Claim Guardians LLC",
          "areaServed": "Florida",
          "member": [
            {
              "@type": "Person",
              "name": "Alejandro Sibila",
              "jobTitle": "Principal Public Adjuster",
              "description": "State Licensed Public Adjuster in Florida and California (License # W116187)"
            }
          ]
        }
      }
    </script>
  </Fragment>

  <!-- 1. Hero Section (Maximum Authority & Trust) -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero-team-adjusters.png" 
        alt="Claim Guardians public adjusters team inspecting property damage in Florida" 
        class="w-full h-full object-cover opacity-60 scale-105" 
        fetchpriority="high"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#002D51]/20 to-[#041224]"></div>
    </div>
    
    <div class="section-inner relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-10 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white font-bold" aria-current="page">Company</li>
        </ol>
      </nav>

      <div class="max-w-4xl mx-auto">
        <span class="eyebrow" style="color:#00B5A6;">The Advocacy Firm</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white mb-8 leading-[1.1] tracking-tight">
          Claim Guardians <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00808C] to-[#00B5A6]">Fights the Insurance Giants</span> For You.
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed font-medium">
          We founded Claim Guardians to level the playing field. Large insurance corporations employ armies of adjusters to protect their profits. We work exclusively for property owners to protect your financial future.
        </p>
      </div>
    </div>
  </header>

  <!-- 2. Our Financial Guarantee -->
  <section class="section-white" style="margin-top: -4rem;">
    <div class="section-inner relative z-20">
      <div class="card-hover p-1 md:p-1.5 shadow-2xl">
        <div class="bg-white rounded-[22px] md:rounded-[20px] p-10 md:p-16 relative overflow-hidden">
          <div class="flex flex-col md:flex-row gap-12 items-center">
            <div class="md:w-1/3 text-center md:text-left">
              <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-blue-50 text-4xl mb-6 border border-blue-100 shadow-inner">🛡️</div>
              <h2 class="text-3xl font-extrabold text-[#082142] leading-tight mb-4">
                The Claim Guardians <br/><span class="text-[#00808C]">No-Recovery, No-Fee</span> Promise.
              </h2>
            </div>
            
            <div class="md:w-2/3">
              <ul class="space-y-6">
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">We charge $0 for your initial property inspection.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">You pay zero out-of-pocket costs during the process.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">Claim Guardians advances all costs for experts and documentation.</span>
                </li>
                <li class="flex items-start gap-5">
                  <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-50 text-[#00808C] font-bold mt-1 shadow-sm">✓</span>
                  <span class="text-xl font-bold text-[#082142]">We collect a state-regulated percentage ONLY after you receive your check.</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Credentials (EEAT) -->
  <section class="section-muted text-center border-y border-slate-200">
    <div class="section-inner">
      <span class="eyebrow">Proven Authority</span>
      <h2 class="section-heading mb-8">State-Licensed and Certified Experts.</h2>
      <p class="text-xl text-slate-500 leading-relaxed mb-16 max-w-3xl mx-auto font-medium">
        Florida strictly regulates public adjusters. Claim Guardians holds active licenses from the Florida Department of Financial Services (DFS). Our team members are strictly policyholder advocates dedicated to your recovery.
      </p>

      <div class="flex flex-wrap justify-center items-center gap-12 text-slate-400 font-black">
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl grayscale">🛡️</span>
          <span class="text-sm uppercase tracking-widest">DFS Licensed</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl grayscale">⚖️</span>
          <span class="text-sm uppercase tracking-widest">State Bonded</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl grayscale">💰</span>
          <span class="text-sm uppercase tracking-widest">No-Fee Guarantee</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. The Team -->
  <section class="section-white">
    <div class="section-inner">
      <div class="text-center mb-16">
        <span class="eyebrow">Your Guardians</span>
        <h2 class="section-heading">The Elite Advocacy Team.</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 max-w-lg mx-auto">
        <div class="card-testimonial text-center group">
          <div class="w-40 h-40 mx-auto bg-slate-100 rounded-full mb-8 relative overflow-hidden border-4 border-white shadow-2xl group-hover:scale-105 transition-transform">
             <div class="absolute inset-0 flex items-center justify-center text-5xl opacity-20 grayscale">👤</div>
          </div>
          <h3 class="text-2xl font-black text-[#082142] mb-1">Alejandro Sibila</h3>
          <p class="text-[#00808C] font-black text-sm uppercase tracking-widest mb-4">Principal Public Adjuster</p>
          <div class="flex flex-col gap-2 items-center">
            <div class="inline-block px-5 py-2 bg-slate-50 text-slate-500 text-xs font-black rounded-full border border-slate-100 tracking-tighter">LICENSED # W116187</div>
            <div class="flex gap-2">
              <div class="inline-block px-4 py-1.5 bg-slate-50 text-slate-400 text-[10px] font-black rounded-full border border-slate-100 tracking-tighter">FL LICENSED</div>
              <div class="inline-block px-4 py-1.5 bg-slate-50 text-slate-400 text-[10px] font-black rounded-full border border-slate-100 tracking-tighter">CA LICENSED</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Final CTA -->
  <section class="gradient-accent-bar section-white text-center">
    <div class="section-inner">
      <h2 class="section-heading mb-6">Stop Fighting Your Insurance Company Alone.</h2>
      <p class="text-xl text-slate-500 mb-10 font-medium max-w-2xl mx-auto leading-relaxed">
        Claim Guardians takes over the stress today. We focus on the policy so you can focus on your recovery.
      </p>
      <a href="/free-claim-review" class="btn-accent px-12 py-5 text-2xl min-h-[64px]">Schedule Free Consultation →</a>
      <p class="text-sm text-slate-400 mt-4">Zero upfront cost. Guaranteed.</p>
    </div>
  </section>

</BaseLayout>
