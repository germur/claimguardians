---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Claim Guardians | Company & EEAT Credentials" 
  description="We work exclusively for property owners to protect your financial future. Florida-licensed, BBB A+ rated public adjusters."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "mainEntity": {
          "@type": "Organization",
          "name": "Claim Guardians LLC",
          "areaServed": "Florida",
          "member": [
            {
              "@type": "Person",
              "name": "Jane Doe",
              "jobTitle": "Senior Public Adjuster",
              "description": "FL License # 123456"
            },
            {
              "@type": "Person",
              "name": "John Smith",
              "jobTitle": "Lead Claim Appraiser",
              "description": "FL License # 654321"
            }
          ]
        }
      }
    </script>
  </Fragment>

  <!-- 1. Hero Section (Maximum Authority & Trust) -->
  <header class="relative bg-[#0A0F1C] overflow-hidden pt-24 pb-32">
    <!-- Sophisticated Deep Blue/Gold Trust Gradient -->
    <div class="absolute top-0 inset-x-0 h-[600px] bg-gradient-to-b from-slate-900 to-transparent pointer-events-none"></div>
    <div class="absolute -top-[200px] -right-[100px] w-[600px] h-[600px] rounded-full bg-blue-600/10 blur-[120px] pointer-events-none"></div>
    <div class="absolute -bottom-[200px] -left-[100px] w-[500px] h-[500px] rounded-full bg-yellow-500/5 blur-[100px] pointer-events-none"></div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-8 text-center text-white">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-12 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-300 font-medium bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 shadow-lg">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-500">›</span></li>
          <li class="text-white" aria-current="page">Company</li>
        </ol>
      </nav>

      <h1 class="text-5xl md:text-6xl font-extrabold mb-8 leading-[1.1] tracking-tight drop-shadow-2xl">
        Claim Guardians <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-yellow-200">Fights the Insurance Giants</span> For You.
      </h1>
      <h2 class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed font-light">
        We founded Claim Guardians to level the playing field. Large insurance corporations employ armies of adjusters to protect their profits. We work exclusively for property owners to protect your financial future.
      </h2>
    </div>
    
    <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-base-bg to-transparent"></div>
  </header>

  <!-- 2. Our Financial Guarantee (Highlighted Design) -->
  <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative -mt-32 z-20">
    <div class="bg-gradient-to-br from-slate-900 to-[#0A0F1C] rounded-3xl p-1 md:p-1.5 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.5)]">
      <div class="bg-white rounded-[22px] md:rounded-[20px] p-10 md:p-16 relative overflow-hidden">
        <!-- Golden Edge Glow -->
        <div class="absolute top-0 inset-x-0 h-2 bg-gradient-to-r from-transparent via-yellow-400 to-transparent"></div>
        <div class="absolute -right-20 -top-20 w-64 h-64 bg-yellow-400/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="flex flex-col md:flex-row gap-12 items-center">
          <div class="md:w-1/3 text-center md:text-left">
            <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-green-50 text-green-600 text-5xl mb-6 shadow-sm border border-green-100">
              🛡️
            </div>
            <h2 class="text-3xl font-extrabold text-[#111827] leading-tight mb-4">
              The Claim Guardians<br/><span class="text-green-600">"No Recovery, No Fee"</span> Promise.
            </h2>
          </div>
          
          <div class="md:w-2/3">
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-green-600 mt-1">✓</span>
                <span class="text-xl font-medium text-slate-700">We charge $0 for your initial property inspection.</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-green-600 mt-1">✓</span>
                <span class="text-xl font-medium text-slate-700">You pay zero out-of-pocket costs during the process.</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-green-600 mt-1">✓</span>
                <span class="text-xl font-medium text-slate-700">Claim Guardians advances all costs for experts and documentation.</span>
              </li>
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-green-600 mt-1">✓</span>
                <span class="text-xl font-medium text-slate-700">We collect a state-regulated percentage ONLY after you receive your check.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Our Credentials (EEAT Section) -->
  <section class="py-24 bg-slate-50 border-y border-slate-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-8">
        State-Licensed and Certified Experts.
      </h2>
      <p class="text-xl text-slate-600 leading-relaxed mb-16 max-w-3xl mx-auto">
        Florida strictly regulates public adjusters. Claim Guardians holds active licenses from the Florida Department of Financial Services. Our team members belong to the Florida Association of Public Insurance Adjusters (FAPIA).
      </p>

      <!-- Trust Logos Placeholder Row -->
      <div class="flex flex-wrap justify-center items-center gap-12 opacity-70 grayscale hover:grayscale-0 transition-all duration-300">
        <div class="h-16 w-32 bg-slate-200 rounded flex items-center justify-center font-bold text-slate-400">FL Dept. Finance</div>
        <div class="h-16 w-32 bg-slate-200 rounded flex items-center justify-center font-bold text-slate-400">FAPIA Member</div>
        <div class="h-16 w-32 bg-slate-200 rounded flex items-center justify-center font-bold text-slate-400">BBB A+ Rated</div>
      </div>
    </div>
  </section>

  <!-- 4. Meet the Guardians -->
  <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-6">
        Your Dedicated Advocacy Team.
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <!-- Profile 1 -->
      <div class="card-surface group text-center hover:border-blue-300">
        <div class="w-32 h-32 mx-auto bg-slate-200 rounded-full mb-6 relative overflow-hidden border-4 border-white shadow-xl group-hover:scale-105 transition-transform">
          <!-- Placeholder avatar -->
          <div class="absolute inset-0 flex items-center justify-center text-4xl text-slate-400">👤</div>
        </div>
        <h3 class="text-2xl font-bold text-[#111827] mb-1">Jane Doe</h3>
        <p class="text-primary-600 font-semibold mb-3">Senior Public Adjuster</p>
        <div class="inline-block px-4 py-1.5 bg-slate-100 text-slate-600 text-sm font-bold rounded-full font-mono">
          FL License # 123456
        </div>
      </div>

      <!-- Profile 2 -->
      <div class="card-surface group text-center hover:border-blue-300">
        <div class="w-32 h-32 mx-auto bg-slate-200 rounded-full mb-6 relative overflow-hidden border-4 border-white shadow-xl group-hover:scale-105 transition-transform">
          <!-- Placeholder avatar -->
          <div class="absolute inset-0 flex items-center justify-center text-4xl text-slate-400">👤</div>
        </div>
        <h3 class="text-2xl font-bold text-[#111827] mb-1">John Smith</h3>
        <p class="text-primary-600 font-semibold mb-3">Lead Claim Appraiser</p>
        <div class="inline-block px-4 py-1.5 bg-slate-100 text-slate-600 text-sm font-bold rounded-full font-mono">
          FL License # 654321
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Call to Action Final -->
  <section class="py-24 bg-primary-900 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">
        Stop Fighting Your Insurance Company Alone.
      </h2>
      <p class="text-xl text-primary-200 mb-10 font-light max-w-2xl mx-auto">
        Claim Guardians takes over the stress today.
      </p>
      <a href="/free-claim-review" class="group relative inline-flex justify-center items-center px-12 py-5 text-xl font-bold text-white bg-accent-600 rounded-xl overflow-hidden shadow-[0_0_40px_-5px_rgba(234,88,12,0.8)] hover:shadow-[0_0_60px_-5px_rgba(234,88,12,1)] hover:scale-105 transition-all duration-300">
        <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-[100%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
        <span class="relative">Schedule Your Free Consultation</span>
      </a>
    </div>
  </section>

</BaseLayout>
