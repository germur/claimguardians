---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="404 - Page Not Found | Claim Guardians" 
  description="The page you are looking for has been lost in the storm. Return to safety with Claim Guardians."
>
  <section class="relative bg-[#041224] min-h-[80vh] flex items-center overflow-hidden">
    <!-- Atmospheric Background -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-hurricane-damage.png" alt="Storm damage context" class="w-full h-full object-cover opacity-40 grayscale blur-sm" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/40 via-[#041224]/30 to-[#041224]"></div>
    </div>

    <div class="section-inner relative z-10 text-center py-20">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-slate-100/5 border border-white/10 mb-10 text-6xl shadow-2xl backdrop-blur-md">
        🌪️
      </div>
      <h1 class="text-7xl md:text-9xl font-black text-white mb-6 tracking-tighter drop-shadow-2xl">404</h1>
      <h2 class="text-3xl md:text-5xl font-extrabold text-[#00B5A6] mb-8">Lost in the Storm?</h2>
      <p class="text-xl md:text-2xl text-slate-300 max-w-2xl mx-auto mb-16 font-medium leading-relaxed">
        It looks like this page was swept away. Don't worry, Claim Guardians can help you navigate back to safety.
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="/" class="btn-primary px-10 py-5 text-xl font-black rounded-2xl shadow-2xl">Return to Homepage</a>
        <a href="/free-claim-review" class="btn-accent px-10 py-5 text-xl font-black rounded-2xl shadow-2xl shadow-[#00808C]/40">Start Free Review →</a>
      </div>

      <div class="mt-24">
        <p class="text-sm font-black text-slate-500 uppercase tracking-[0.3em] mb-10">Common Safe Harbors</p>
        <div class="flex flex-wrap justify-center gap-6">
          <a href="/services/water-damage" class="px-6 py-3 bg-white/5 border border-white/10 rounded-xl text-white font-bold hover:bg-white/10 transition-all">Water Damage</a>
          <a href="/services/hurricane-damage" class="px-6 py-3 bg-white/5 border border-white/10 rounded-xl text-white font-bold hover:bg-white/10 transition-all">Hurricane</a>
          <a href="/services/roof-damage" class="px-6 py-3 bg-white/5 border border-white/10 rounded-xl text-white font-bold hover:bg-white/10 transition-all">Roof Damage</a>
          <a href="/service-areas" class="px-6 py-3 bg-white/5 border border-white/10 rounded-xl text-white font-bold hover:bg-white/10 transition-all">Service Areas</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
