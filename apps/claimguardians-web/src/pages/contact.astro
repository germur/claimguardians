---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact Us | Claim Guardians Public Adjusters Florida" 
  description="Contact Claim Guardians for immediate assistance with your property damage claim. 24/7 service across Florida. Phone: (555) 123-4567."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "mainEntity": {
          "@type": "LocalBusiness",
          "name": "Claim Guardians LLC",
          "image": "https://www.claimguardians.com/images/hero-team-adjusters.png",
          "telePhone": "(555) 123-4567",
          "email": "claims@claimguardians.com",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "123 Adjuster Way, Suite 400",
            "addressLocality": "Miami",
            "addressRegion": "FL",
            "postalCode": "33101",
            "addressCountry": "US"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": "25.7617",
            "longitude": "-80.1918"
          },
          "url": "https://www.claimguardians.com/contact",
          "openingHours": "Mo-Su 00:00-23:59"
        }
      }
    </script>
  </Fragment>

  <!-- 1. Hero -->
  <header class="relative bg-[#041224] overflow-hidden" style="padding-top:8rem; padding-bottom:8rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-city-florida.png" alt="Florida skyline - Contact Claim Guardians" class="w-full h-full object-cover opacity-25 scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/85 via-[#002D51]/65 to-white"></div>
    </div>
    <div class="section-inner relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-8 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white font-bold" aria-current="page">Contact</li>
        </ol>
      </nav>
      <div class="max-w-3xl mx-auto">
        <span class="eyebrow" style="color:#00B5A6;">Immediate Response</span>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6">How Can We <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00808C] to-[#00B5A6]">Help Today?</span></h1>
        <p class="text-xl text-slate-300 font-medium leading-relaxed">
          Whether you have a new loss or a denied claim, our team is ready to respond 24/7 anywhere in Florida.
        </p>
      </div>
    </div>
  </header>

  <!-- 2. Dual Column Layout -->
  <section class="section-white" style="margin-top:-6rem;">
    <div class="section-inner relative z-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Contact Information -->
        <div class="space-y-12">
          <div>
            <h2 class="text-4xl font-black text-[#082142] mb-6">Direct Channels</h2>
            <p class="text-lg text-slate-500 font-medium leading-relaxed">
              We understand the urgency of property damage. Use any of the following methods for a rapid-response consultation.
            </p>
          </div>

          <div class="space-y-8">
            <a href="tel:5551234567" class="card-hover flex items-center gap-6 p-8 group">
              <div class="w-16 h-16 rounded-2xl bg-slate-50 flex items-center justify-center text-4xl group-hover:scale-110 transition-transform shadow-inner">📞</div>
              <div>
                <p class="text-sm font-black text-[#00808C] uppercase tracking-widest mb-1">Call 24/7</p>
                <p class="text-2xl font-black text-[#082142] group-hover:text-[#00808C] transition-colors">(555) 123-4567</p>
              </div>
            </a>

            <a href="mailto:claims@claimguardians.com" class="card-hover flex items-center gap-6 p-8 group">
              <div class="w-16 h-16 rounded-2xl bg-slate-50 flex items-center justify-center text-4xl group-hover:scale-110 transition-transform shadow-inner">✉️</div>
              <div>
                <p class="text-sm font-black text-[#00808C] uppercase tracking-widest mb-1">Email Us</p>
                <p class="text-2xl font-black text-[#082142] group-hover:text-[#00808C] transition-colors">claims@claimguardians.com</p>
              </div>
            </a>

            <div class="card-hover flex items-center gap-6 p-8 group">
              <div class="w-16 h-16 rounded-2xl bg-slate-50 flex items-center justify-center text-4xl group-hover:scale-110 transition-transform shadow-inner">📍</div>
              <div>
                <p class="text-sm font-black text-[#00808C] uppercase tracking-widest mb-1">Florida Office</p>
                <p class="text-xl font-black text-[#082142]">123 Adjuster Way, Suite 400<br/>Miami, FL 33101</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Rapid Inquiry Form -->
        <div class="bg-white rounded-3xl p-10 md:p-12 shadow-2xl border-2 border-slate-100 ring-1 ring-slate-200">
           <h3 class="text-2xl font-black text-[#082142] mb-8 border-b border-slate-100 pb-4">Send a Message</h3>
           <form class="space-y-6" action="#" method="POST">
             <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="c-name" class="block text-sm font-black text-slate-700 ml-1">Full Name</label>
                  <input type="text" id="c-name" required class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#00808C] outline-none text-slate-900 font-bold min-h-[56px]" placeholder="Jane Doe" />
                </div>
                <div class="space-y-2">
                  <label for="c-phone" class="block text-sm font-black text-slate-700 ml-1">Phone</label>
                  <input type="tel" id="c-phone" required class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#00808C] outline-none text-slate-900 font-bold min-h-[56px]" placeholder="(555) 000-0000" />
                </div>
             </div>
             <div class="space-y-2">
                <label for="c-email" class="block text-sm font-black text-slate-700 ml-1">Email</label>
                <input type="email" id="c-email" required class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#00808C] outline-none text-slate-900 font-bold min-h-[56px]" placeholder="jane@example.com" />
             </div>
             <div class="space-y-2">
                <label for="c-msg" class="block text-sm font-black text-slate-700 ml-1">How can we help?</label>
                <textarea id="c-msg" rows="5" class="w-full px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#00808C] outline-none text-slate-900 font-bold resize-none" placeholder="Details about your claim..."></textarea>
             </div>
             <button type="submit" class="btn-accent w-full py-5 text-xl min-h-[64px] rounded-2xl">Send Message →</button>
           </form>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. Final Trust -->
  <section class="section-muted text-center">
    <div class="section-inner">
      <h4 class="text-sm font-black uppercase tracking-widest text-[#00808C] mb-8">Serving All 67 Florida Counties</h4>
      <div class="flex flex-wrap justify-center gap-8 opacity-40 grayscale font-black text-slate-400">
        <span>MIAMI-DADE</span>
        <span>BROWARD</span>
        <span>PALM BEACH</span>
        <span>ORLANDO</span>
        <span>TAMPA</span>
        <span>JACKSONVILLE</span>
      </div>
    </div>
  </section>

</BaseLayout>
