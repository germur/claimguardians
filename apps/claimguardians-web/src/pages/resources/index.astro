---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Claim Guardians | Insurance Claim Resources & Vocabulary" 
  description="Insurance companies use confusing legal jargon to underpay claims. Our resource center breaks down industry terms and claims processes."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [{
          "@type": "Question",
          "name": "What is an Estimated Maximum Loss (EML)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "EML is the highest potential financial loss a property could suffer from a single event. Claim Guardians calculates your EML to prevent the insurance company from capping your payout."
          }
        }, {
          "@type": "Question",
          "name": "What is the Saffir-Simpson Scale?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Saffir-Simpson Hurricane Wind Scale classifies hurricanes from Category 1 to 5 based on sustained wind speed. Claim Guardians uses this data to prove the severity of your wind damage."
          }
        }]
      }
    </script>
  </Fragment>

  <!-- 1. Hero Section (Knowledge Base Feel) -->
  <header class="relative bg-[#0A0F1C] overflow-hidden pt-24 pb-32">
    <!-- Dynamic Glowing Gradient Mesh Background -->
    <div class="absolute top-0 inset-x-0 h-[600px] bg-gradient-to-b from-primary-900/50 to-transparent pointer-events-none"></div>
    <div class="absolute -top-[300px] -right-[200px] w-[800px] h-[800px] rounded-full bg-primary-600/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute -bottom-[200px] -left-[200px] w-[600px] h-[600px] rounded-full bg-accent-600/10 blur-[100px] pointer-events-none"></div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-8 text-center text-white">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-12 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-300 font-medium bg-white/5 backdrop-blur-md px-4 py-2 rounded-full border border-white/10 shadow-lg">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-500">›</span></li>
          <li class="text-white" aria-current="page">Resources</li>
        </ol>
      </nav>

      <h1 class="text-5xl md:text-6xl font-extrabold mb-8 leading-[1.1] tracking-tight drop-shadow-2xl">
        Claim Guardians Translates <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-blue-200">Complex Insurance Policies.</span>
      </h1>
      <h2 class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed font-light">
        Insurance companies use confusing legal jargon to underpay claims. Our resource center breaks down industry terms and claims processes. We empower you with clear, actionable knowledge.
      </h2>

      <!-- Visual Search Bar (KB Style) -->
      <div class="relative max-w-2xl mx-auto">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text" placeholder="Search insurance terms, guides, or questions..." class="w-full pl-12 pr-4 py-5 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl text-white placeholder-slate-400 focus:outline-none focus:ring-4 focus:ring-primary-500/50 shadow-2xl text-lg transition-all">
      </div>
    </div>
    
    <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-base-bg to-transparent"></div>
  </header>

  <!-- 2. Knowledge Categories -->
  <section class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-6">
        Explore Our Insurance Claim Resources.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Card 1 (Guides) -->
      <a href="/resources/guides" class="card-surface group hover:border-primary-300">
        <div class="text-4xl mb-4">📚</div>
        <h3 class="text-2xl font-bold text-[#111827] mb-3 group-hover:text-primary-600 transition-colors">Claim Survival Guides</h3>
        <p class="text-lg text-text-muted">Step-by-step instructions for filing and appealing claims.</p>
      </a>

      <!-- Card 2 (Glossary) -->
      <a href="/resources/glossary" class="card-surface group hover:border-primary-300">
        <div class="text-4xl mb-4">📖</div>
        <h3 class="text-2xl font-bold text-[#111827] mb-3 group-hover:text-primary-600 transition-colors">Insurance Terms Glossary</h3>
        <p class="text-lg text-text-muted">Plain-English definitions of complex insurance vocabulary.</p>
      </a>

      <!-- Card 3 (Comparisons) -->
      <a href="/resources/comparisons" class="card-surface group hover:border-primary-300">
        <div class="text-4xl mb-4">⚖️</div>
        <h3 class="text-2xl font-bold text-[#111827] mb-3 group-hover:text-primary-600 transition-colors">Us vs. Them</h3>
        <p class="text-lg text-text-muted">Detailed comparisons between public adjusters and insurance company adjusters.</p>
      </a>

      <!-- Card 4 (Legal Rights) -->
      <a href="/resources/rights" class="card-surface group hover:border-primary-300">
        <div class="text-4xl mb-4">🛡️</div>
        <h3 class="text-2xl font-bold text-[#111827] mb-3 group-hover:text-primary-600 transition-colors">Florida Policyholder Rights</h3>
        <p class="text-lg text-text-muted">Understand your legal protections under Florida state law.</p>
      </a>
    </div>
  </section>

  <!-- 3. Featured AEO Answers -->
  <section class="bg-primary-50 py-24 border-t border-primary-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-12 text-center">
        Instant Answers to Common Questions.
      </h2>

      <div class="space-y-8">
        <!-- Block 1 -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm relative overflow-hidden">
          <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-accent-500"></div>
          <h3 class="text-xl font-bold text-primary-700 mb-4">What is an Estimated Maximum Loss (EML)?</h3>
          <p class="text-lg text-[#111827] leading-relaxed">
            <span class="font-bold text-slate-500 uppercase text-xs tracking-wider block mb-1">Definition:</span>
            EML is the highest potential financial loss a property could suffer from a single event. Claim Guardians calculates your EML to prevent the insurance company from capping your payout.
          </p>
        </div>

        <!-- Block 2 -->
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm relative overflow-hidden">
          <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-accent-500"></div>
          <h3 class="text-xl font-bold text-primary-700 mb-4">What is the Saffir-Simpson Scale?</h3>
          <p class="text-lg text-[#111827] leading-relaxed">
            <span class="font-bold text-slate-500 uppercase text-xs tracking-wider block mb-1">Definition:</span>
            The Saffir-Simpson Hurricane Wind Scale classifies hurricanes from Category 1 to 5 based on sustained wind speed. Claim Guardians uses this data to prove the severity of your wind damage.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
