---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Free Claim Review | Claim Guardians" 
  description="Request a free, no-obligation property damage inspection and claim review from Florida's elite public adjusters."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "name": "Claim Guardians Free Claim Review",
        "description": "Contact Claim Guardians for a free property damage assessment and insurance claim review in Florida.",
        "url": "https://www.claimguardians.com/free-claim-review",
        "mainEntity": {
          "@type": "LocalBusiness",
          "name": "Claim Guardians LLC",
          "telephone": "(555) 123-4567",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "123 Adjuster Way, Suite 400",
            "addressLocality": "Miami",
            "addressRegion": "FL",
            "postalCode": "33101",
            "addressCountry": "US"
          }
        }
      }
    </script>
  </Fragment>

  <!-- 1. Split Layout Context (Form Left / Trust Right) -->
  <div class="bg-base-bg min-h-screen pt-20 pb-24 relative overflow-hidden">
    <!-- Ambient Background Effects -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-gradient-to-bl from-primary-600/10 via-primary-400/5 to-transparent rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-accent-600/5 rounded-full blur-[100px] pointer-events-none translate-y-1/2 -translate-x-1/2"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Page Header -->
      <div class="text-center mb-16 mt-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#111827] tracking-tight mb-4 drop-shadow-sm">
          Secure Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-primary-400">Maximum Settlement.</span>
        </h1>
        <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto font-medium">
          Tell us what happened. Our senior adjusters will review your policy and damage for free, and outline exactly how much your insurer owes you.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
        
        <!-- Action Column: The Lead Form (7 Cols) -->
        <div class="lg:col-span-7 bg-white rounded-3xl p-8 md:p-12 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] border border-slate-100 relative overflow-hidden">
          
          <!-- Subtle Form Decorator -->
          <div class="absolute top-0 inset-x-0 h-2 bg-gradient-to-r from-[#00808C] to-[#00B5A6]"></div>

          <h2 class="text-2xl font-bold text-slate-900 mb-8 border-b border-slate-100 pb-4">Claim Details</h2>
          
          <form class="space-y-6" action="#" method="POST" onSubmit="event.preventDefault(); alert('Lead Submission Triggered (Integration Pending)');">
            
            <!-- Personal Info Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="firstName" class="block text-sm font-semibold text-slate-700">First Name</label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900" 
                  placeholder="John" />
              </div>
              <div class="space-y-2">
                <label for="lastName" class="block text-sm font-semibold text-slate-700">Last Name</label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900" 
                  placeholder="Doe" />
              </div>
            </div>

            <!-- Contact Info Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="email" class="block text-sm font-semibold text-slate-700">Email Address</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900" 
                  placeholder="john@example.com" />
              </div>
              <div class="space-y-2">
                <label for="phone" class="block text-sm font-semibold text-slate-700">Phone Number</label>
                <input type="tel" id="phone" name="phone" required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900" 
                  placeholder="(555) 123-4567" />
              </div>
            </div>

            <!-- Property Info -->
            <div class="space-y-2 mt-8 border-t border-slate-100 pt-8">
              <label for="propertyType" class="block text-sm font-semibold text-slate-700">Property Type</label>
              <select id="propertyType" name="propertyType" required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900 appearance-none">
                <option value="" disabled selected>Select Property Type...</option>
                <option value="residential">Residential (Home, Condo)</option>
                <option value="commercial">Commercial (Business, Warehouse)</option>
                <option value="association">HOA / Condominium Association</option>
              </select>
            </div>

            <div class="space-y-2">
              <label for="damageType" class="block text-sm font-semibold text-slate-700">Primary Damage Type</label>
              <select id="damageType" name="damageType" required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900 appearance-none">
                <option value="" disabled selected>What caused the damage?</option>
                <option value="water">💧 Water Leak / Pipe Burst</option>
                <option value="hurricane">🌪️ Hurricane / Wind Event</option>
                <option value="roof">🏠 Roof Damage</option>
                <option value="fire">🔥 Fire / Smoke</option>
                <option value="mold">🦠 Mold Intrusion</option>
                <option value="denied">⚖️ Modifying a Denied/Underpaid Claim</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Description -->
            <div class="space-y-2">
              <label for="description" class="block text-sm font-semibold text-slate-700">Briefly detail what happened <span class="text-slate-400 font-normal">(Optional)</span></label>
              <textarea id="description" name="description" rows="4" 
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-all outline-none text-slate-900 resize-none" 
                placeholder="E.g., A pipe burst in the master bathroom yesterday morning..."></textarea>
            </div>

            <!-- Submit -->
            <div class="pt-6">
              <button type="submit" class="w-full flex justify-center py-4 px-8 border border-transparent rounded-xl shadow-[0_0_30px_-5px_var(--color-brand-cyan)] text-lg font-bold text-white bg-gradient-to-r from-accent-600 to-accent-500 hover:from-accent-500 hover:to-accent-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-500 transition-all duration-300 transform hover:-translate-y-1">
                Submit for Free Review
              </button>
              <p class="text-xs text-center text-slate-400 mt-4">
                By submitting this form, you agree to our <a href="/company/privacy-policy" class="underline hover:text-slate-600">Privacy Policy</a>. We never sell your data.
              </p>
            </div>
          </form>
        </div>

        <!-- Trust Column: Why Choose Us (5 Cols) -->
        <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-32">
          
          <!-- Urgent Contact Card (Dark Vibe) -->
          <div class="bg-primary-900 rounded-3xl p-8 sm:p-10 shadow-xl border border-primary-700 relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-10"></div>
            <div class="relative z-10 text-center text-white">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/20 text-red-400 text-3xl mb-6 shadow-[0_0_20px_rgba(220,38,38,0.4)]">
                🚨
              </div>
              <h3 class="text-2xl font-bold mb-3">Emergency Situation?</h3>
              <p class="text-primary-200 mb-8 font-light leading-relaxed">
                If your property is currently exposed or facing active water/fire damage, bypass the form and call our 24/7 hotline immediately for mitigation coordination.
              </p>
              <a href="tel:5551234567" class="inline-flex justify-center items-center w-full px-6 py-4 text-xl font-bold text-white bg-white/10 backdrop-blur-md border border-white/20 rounded-xl hover:bg-white/20 transition-all duration-300 shadow-lg">
                (555) 123-4567
              </a>
            </div>
          </div>

          <!-- Trust Badges List -->
           <div class="bg-white rounded-3xl p-8 sm:p-10 shadow-md border border-slate-100">
             <h4 class="text-lg font-bold text-slate-900 mb-6 uppercase tracking-wide border-b border-slate-100 pb-4">The Guardians Guarantee</h4>
             
             <ul class="space-y-6">
               <li class="flex items-start gap-4">
                 <div class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold mt-1">✓</div>
                 <div>
                   <h5 class="font-bold text-slate-900">Zero Upfront Fees</h5>
                   <p class="text-sm text-slate-500 mt-1">We don't get paid a single dime until you have your settlement check in hand.</p>
                 </div>
               </li>
               <li class="flex items-start gap-4">
                 <div class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold mt-1">✓</div>
                 <div>
                   <h5 class="font-bold text-slate-900">Licensed FAPIA Experts</h5>
                   <p class="text-sm text-slate-500 mt-1">Fully credentialed and bonded structural damage adjusters recognized by the State of Florida.</p>
                 </div>
               </li>
               <li class="flex items-start gap-4">
                 <div class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-600 font-bold mt-1">✓</div>
                 <div>
                   <h5 class="font-bold text-slate-900">Forensic Case Building</h5>
                   <p class="text-sm text-slate-500 mt-1">We utilize thermal imaging, moisture meters, and 3D scans to prove your damage is covered.</p>
                 </div>
               </li>
             </ul>
           </div>

        </div>

      </div>
    </div>
  </div>

</BaseLayout>
