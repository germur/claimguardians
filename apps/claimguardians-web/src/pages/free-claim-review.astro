---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm';
---

<BaseLayout 
  title="Free Claim Review | Claim Guardians" 
  description="Request a free, no-obligation property damage inspection and claim review from Florida's elite public adjusters."
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "name": "Claim Guardians Free Claim Review",
        "description": "Contact Claim Guardians for a free property damage assessment and insurance claim review in Florida.",
        "url": "https://www.claimguardians.com/free-claim-review",
        "mainEntity": {
          "@type": "LocalBusiness",
          "name": "Claim Guardians LLC",
          "telephone": "(555) 123-4567",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "123 Adjuster Way, Suite 400",
            "addressLocality": "Miami",
            "addressRegion": "FL",
            "postalCode": "33101",
            "addressCountry": "US"
          }
        }
      }
    </script>
  </Fragment>

  <!-- 1. Hero Content Zone -->
  <section class="relative bg-[#041224] overflow-hidden" style="padding-top:6rem; padding-bottom:12rem;">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-success.png" alt="Successful insurance settlement check" class="w-full h-full object-cover opacity-20 scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#041224]/90 via-[#002D51]/70 to-white"></div>
    </div>
    
    <div class="section-inner relative z-10 text-center">
      <nav aria-label="Breadcrumb" class="mb-8 inline-flex">
        <ol class="flex items-center space-x-2 text-sm text-slate-400 font-medium bg-white/5 px-4 py-2 rounded-full border border-white/10">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="mx-2 text-slate-600">›</span></li>
          <li class="text-white font-bold" aria-current="page">Free Review</li>
        </ol>
      </nav>

      <div class="max-w-3xl mx-auto">
        <span class="eyebrow" style="color:#00B5A6;">Zero-Cost Policy Review</span>
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white mb-6 tracking-tight leading-[1.1]">
          Secure Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00808C] to-[#00B5A6]">Maximum Legal Settlement.</span>
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed font-medium">
          Tell us about your loss. Our senior adjusters will review your policy and damage for free, outlining exactly what your insurer legally owes you.
        </p>
      </div>
    </div>
  </section>

  <!-- 2. Dual Column Conversion Zone -->
  <section class="section-white" style="margin-top: -8rem;">
    <div class="section-inner relative z-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- FORM COLUMN (7 Cols) -->
        <div class="lg:col-span-7">
          <LeadForm client:load />
        </div>

        <!-- TRUST COLUMN (5 Cols) -->
        <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-32">
          
          <!-- Emergency CTA Card -->
          <div class="section-dark p-8 md:p-10 rounded-3xl relative overflow-hidden shadow-2xl group border border-white/5">
            <div class="absolute top-0 right-0 w-32 h-32 bg-red-500/10 rounded-full -translate-y-1/2 translate-x-1/2 blur-2xl group-hover:bg-red-500/20 transition-colors"></div>
            <div class="relative z-10">
              <div class="text-4xl mb-6 inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/10 border border-red-500/20 animate-pulse">🚨</div>
              <h3 class="text-2xl font-bold text-white mb-4">Emergency Situation?</h3>
              <p class="text-blue-100 text-lg mb-8 font-light leading-relaxed">
                If you have active fire, water, or storm damage, bypass the form and call our 24/7 hotline immediately for rapid dispatch.
              </p>
              <a href="tel:5551234567" class="btn-accent w-full justify-center text-2xl py-6 rounded-2xl shadow-[0_20px_40px_-10px_rgba(0,128,140,0.4)]">
                (555) 123-4567
              </a>
            </div>
          </div>

          <!-- The Guardians Guarantee -->
          <div class="card-hover p-10">
            <h4 class="text-sm font-black uppercase tracking-[0.2em] text-[#00808C] mb-8 border-b border-slate-100 pb-4">The Guarantee</h4>
            <ul class="space-y-8">
              <li class="flex items-start gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-[#082142] font-black shadow-sm">01</div>
                <div>
                  <h5 class="text-lg font-extrabold text-[#082142]">Zero Upfront Costs</h5>
                  <p class="text-slate-500 font-medium">We only collect a fee after you have your settlement check in hand. No recovery, no fee.</p>
                </div>
              </li>
              <li class="flex items-start gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-[#082142] font-black shadow-sm">02</div>
                <div>
                  <h5 class="text-lg font-extrabold text-[#082142]">Licensed &amp; Bonded</h5>
                  <p class="text-slate-500 font-medium">State-licensed Public Adjusters (FAPIA) working exclusively for policyholders, never the insurer.</p>
                </div>
              </li>
              <li class="flex items-start gap-5">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-[#082142] font-black shadow-sm">03</div>
                <div>
                  <h5 class="text-lg font-extrabold text-[#082142]">Forensic Documentation</h5>
                  <p class="text-slate-500 font-medium">We use thermal imaging and moisture meters to prove damage adjusters "missed."</p>
                </div>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- 3. Bottom Proof Banner -->
  <section class="section-muted border-t border-slate-200">
    <div class="section-inner text-center">
      <p class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-8">Claim Guardians is Trusted by Thousands Across Florida</p>
      <div class="flex flex-wrap justify-center items-center gap-12 grayscale opacity-40">
        <div class="h-12 w-32 bg-slate-300 rounded flex items-center justify-center font-bold">FL DEPT FINANCE</div>
        <div class="h-12 w-24 bg-slate-300 rounded flex items-center justify-center font-bold">FAPIA</div>
        <div class="h-12 w-24 bg-slate-300 rounded flex items-center justify-center font-bold">BBB A+</div>
        <div class="h-12 w-32 bg-slate-300 rounded flex items-center justify-center font-bold">NAPIA</div>
      </div>
    </div>
  </section>

</BaseLayout>
